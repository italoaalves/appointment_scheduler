<% content_for :email_preheader, t("booking.confirmation_email.intro") %>
<% content_for :email_eyebrow, "Booking" %>
<% content_for :email_title, t("booking.confirmation_email.greeting", business_name: @space.name) %>
<% content_for :email_intro, "We’ve recorded your request and shared the details below so everything is easy to verify." %>
<% if @confirmation_url.present? %>
  <% content_for :email_cta_label, t("booking.confirmation_email.cta") %>
  <% content_for :email_cta_url, @confirmation_url %>
<% end %>

<p style="margin: 0 0 16px;"><%= t("booking.confirmation_email.intro") %></p>

<%= render "shared/mailer/metadata", rows: [
  { label: t("booking.thank_you.date"), value: @date_str },
  { label: t("booking.thank_you.time"), value: @time_str },
  { label: t("booking.thank_you.duration"), value: t("booking.thank_you.duration_minutes", count: @duration) },
  { label: t("booking.thank_you.status"), value: t("booking.confirmation_email.status_message") }
] %>

<% if @space.booking_success_message.present? %>
  <%= render "shared/mailer/callout",
             title: "Note from #{@space.name}",
             tone: "info",
             content: simple_format(@space.booking_success_message, {}, wrapper_tag: "div") %>
<% end %>
