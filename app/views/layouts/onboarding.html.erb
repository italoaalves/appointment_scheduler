<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : t("layout.app_name") %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen" style="background: linear-gradient(160deg, #ffffff, #f0f9ff, #e0f2fe);">
    <%= render "shared/email_confirmation_banner" if user_signed_in? && !current_user.confirmed? %>
    <header class="border-b border-slate-200 bg-white px-4 py-3">
      <%= link_to t("layout.app_name"), root_path, class: "text-sm font-semibold text-slate-900" %>
    </header>
    <%= render "shared/flash_messages", container_class: "max-w-lg" %>
    <main class="mx-auto max-w-lg px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
