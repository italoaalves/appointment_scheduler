<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= t("landing.meta.title", app_name: app_name) %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= t("landing.meta.description") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "flatpickr", "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="landing-shell">
    <div id="flash_messages">
      <%= render "shared/flash_messages" %>
    </div>
    <%= yield %>
  </body>
</html>
