<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || @space&.name || t("layout.app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="min-h-screen text-deep" style="background: linear-gradient(160deg, #ffffff, #f0f9ff, #e0f2fe);">
    <%= render "shared/flash_messages", dismissible: false, container_class: "max-w-xl" %>
    <main class="mx-auto max-w-xl px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
