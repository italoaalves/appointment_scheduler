<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || t("layout.app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets (can layer on top of Tailwind) %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen text-deep" style="background: linear-gradient(160deg, #ffffff 0%, #f0f9ff 50%, #e0f2fe 100%); background-attachment: fixed;">
    <%= render "shared/email_confirmation_banner" if user_signed_in? && !current_user.confirmed? %>
    <% if user_signed_in? %>
      <% if impersonating? %>
        <div class="flex items-center justify-center gap-3 bg-amber-500 px-4 py-2 text-sm font-medium text-amber-900">
          <span><%= t("platform.impersonation.banner", name: current_user.name.presence || current_user.email) %></span>
          <%= button_to t("platform.impersonation.stop"),
                        platform_stop_impersonation_path,
                        method: :post,
                        class: "inline-flex rounded-md bg-amber-600 px-2 py-1 text-xs font-semibold text-amber-900 hover:bg-amber-700" %>
        </div>
      <% end %>
      <% if current_user.super_admin? %>
        <nav data-controller="dropdown" data-action="click@window->dropdown#close" class="bg-deep border-b border-slate-800">
          <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
            <div class="flex h-14 items-center justify-between">
              <div class="flex items-center gap-4">
                <%= link_to t("layout.app_name"), platform_root_path, class: "font-display font-bold text-sm text-white tracking-tight" %>
                <div class="hidden md:flex items-center gap-3 text-sm">
                  <%= link_to t("layout.nav.tenants"), platform_spaces_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  <%= link_to t("layout.nav.platform_users"), platform_users_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  <%= link_to t("layout.nav.platform_billing"), platform_billing_index_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  <%= link_to t("layout.nav.platform_plans"), platform_plans_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  <%= link_to t("layout.nav.platform_credit_bundles"), platform_credit_bundles_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                  <%= link_to t("layout.nav.platform_integrations"), platform_integrations_path, class: "text-slate-200 hover:text-white px-2 py-1 rounded-md hover:bg-slate-800 transition" %>
                </div>
              </div>
              <div class="hidden md:flex items-center gap-2">
                <div class="relative" data-controller="dropdown" data-action="click@window->dropdown#close">
                  <button type="button"
                          class="inline-flex items-center justify-center rounded-full bg-slate-800 p-2 text-slate-200 hover:bg-slate-700 hover:text-white focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-slate-900"
                          data-action="dropdown#toggle"
                          aria-haspopup="true"
                          aria-label="<%= t('layout.nav.profile') %>">
                    <%= render "shared/icons/user" %>
                  </button>
                  <div data-dropdown-target="menu"
                       class="hidden absolute right-0 top-full z-50 mt-2 min-w-[200px] rounded-md bg-slate-800 py-1 shadow-lg ring-1 ring-slate-700">
                    <div class="border-b border-slate-700 px-3 py-2">
                      <p class="text-xs font-medium text-white truncate"><%= current_user.name.presence || current_user.email %></p>
                      <p class="text-xs text-slate-400 truncate"><%= current_user.email %></p>
                    </div>
                    <%= link_to edit_profile_path, class: "block px-3 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white" do %>
                      <%= t("layout.nav.profile") %>
                    <% end %>
                    <%= link_to edit_preferences_path, class: "block px-3 py-2 text-sm text-slate-200 hover:bg-slate-700 hover:text-white" do %>
                      <%= t("layout.nav.preferences") %>
                    <% end %>
                    <div class="border-t border-slate-700">
                      <%= button_to t("layout.nav.logout"),
                                    destroy_user_session_path,
                                    method: :delete,
                                    data: { turbo: false },
                                    class: "block w-full px-3 py-2 text-left text-sm text-slate-200 hover:bg-slate-700 hover:text-white" %>
                    </div>
                  </div>
                </div>
              </div>
              <div class="flex items-center md:hidden">
                <button type="button"
                        class="inline-flex items-center justify-center rounded-md p-1.5 text-slate-200 hover:bg-slate-800 hover:text-white focus:outline-none focus:ring-2 focus:ring-white"
                        data-action="dropdown#toggle"
                        aria-label="Toggle navigation"
                        aria-haspopup="true">
                  <span data-dropdown-target="openIcon"><%= render "shared/icons/menu" %></span>
                  <span data-dropdown-target="closeIcon" class="hidden"><%= render "shared/icons/close" %></span>
                </button>
              </div>
            </div>
            <div class="md:hidden hidden" data-dropdown-target="menu">
              <div class="space-y-1 pb-3 pt-2">
                <%= link_to t("layout.nav.tenants"), platform_spaces_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <%= link_to t("layout.nav.platform_users"), platform_users_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <%= link_to t("layout.nav.platform_billing"), platform_billing_index_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <%= link_to t("layout.nav.platform_plans"), platform_plans_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <%= link_to t("layout.nav.platform_credit_bundles"), platform_credit_bundles_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <%= link_to t("layout.nav.platform_integrations"), platform_integrations_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                <div class="border-t border-slate-800 mt-2 pt-2 space-y-1 px-3 pb-2">
                  <%= link_to edit_profile_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" do %>
                    <%= t("layout.nav.profile") %>
                  <% end %>
                  <%= link_to edit_preferences_path, class: "block rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" do %>
                    <%= t("layout.nav.preferences") %>
                  <% end %>
                  <%= button_to t("layout.nav.logout"),
                                destroy_user_session_path,
                                method: :delete,
                                data: { turbo: false },
                                class: "block w-full text-left rounded-md px-3 py-2 text-sm font-medium text-slate-100 hover:bg-slate-800" %>
                </div>
              </div>
            </div>
          </div>
        </nav>
      <% elsif tenant_staff? %>
        <% if unread_notifications_count > 0 %>
          <div class="lg:hidden fixed top-4 right-4 z-50" data-controller="dropdown" data-action="click@window->dropdown#close">
            <button type="button"
                    class="relative flex items-center justify-center w-10 h-10 rounded-full bg-white/80 backdrop-blur shadow-sm border border-slate-200/60 text-slate-500 cursor-pointer"
                    data-action="dropdown#toggle"
                    aria-label="<%= t('notifications.in_app.dropdown.title') %>">
              <%= render "shared/icons/bell", class: "h-5 w-5" %>
              <span class="absolute top-1 right-1 flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
              </span>
            </button>
            <div data-dropdown-target="menu" class="hidden absolute right-0 top-full mt-2 z-50 min-w-[280px]">
              <%= render "shared/notification_dropdown" %>
            </div>
          </div>
        <% end %>
        <%= render "shared/right_dock" %>
        <%= render "shared/bottom_nav" %>
      <% end %>
    <% end %>

    <%= render "shared/billing_banner" %>

    <div id="flash_messages">
      <%= render "shared/flash_messages" %>
    </div>

    <main class="mx-auto px-4 py-8 pb-28 sm:pb-8 sm:pr-28 <%= content_for?(:settings_sidebar) ? 'max-w-5xl' : content_for?(:wide_layout) ? 'max-w-6xl' : 'max-w-4xl' %>">
      <%= yield(:breadcrumbs) if content_for?(:breadcrumbs) %>
      <% if content_for?(:settings_sidebar) %>
        <div class="flex flex-col md:flex-row gap-6 md:gap-8">
          <%= yield(:settings_sidebar) %>
          <div class="flex-1 min-w-0">
            <%= yield %>
          </div>
        </div>
      <% else %>
        <%= yield %>
      <% end %>
    </main>
  </body>
</html>
