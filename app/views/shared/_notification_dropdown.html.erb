<div data-role="notification-dropdown-panel"
     class="w-80 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[1.25rem] glass-frosty shadow-xl">
  <div class="border-b border-deep/6 px-3 py-2">
    <p class="text-xs font-semibold uppercase tracking-wider text-slate-400"><%= t("notifications.in_app.dropdown.title") %></p>
  </div>

  <%= turbo_frame_tag "notifications_dropdown", src: notifications_path, loading: :lazy do %>
    <div class="p-2">
      <div class="rounded-xl px-3 py-4 text-center text-sm text-slate-400">...</div>
    </div>
  <% end %>
</div>
