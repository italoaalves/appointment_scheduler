<div data-role="settings-action-bar"
     class="settings-action-bar-floating fixed bottom-0 left-3 z-20 md:static md:px-0 md:pb-0">
  <div data-role="settings-action-bar-panel"
       class="max-w-[calc(100vw-9.5rem)] rounded-[1rem] border border-white/70 bg-white/90 px-3 py-2.5 shadow-lg shadow-slate-200/50 backdrop-blur md:mx-0 md:max-w-none md:rounded-[1.5rem] md:border md:border-white/60 md:bg-white/80 md:px-4 md:py-3 md:shadow-md">
    <div class="flex flex-wrap items-center gap-2 md:flex-col md:items-stretch md:gap-3 lg:flex-row lg:items-center">
      <% if local_assigns[:hint].present? %>
        <p class="hidden text-sm text-slate-500 md:block"><%= hint %></p>
      <% end %>
      <div class="settings-action-bar-buttons">
        <%= yield %>
      </div>
    </div>
  </div>
</div>
