<div class="fixed inset-x-0 bottom-0 z-10 px-3 pb-[calc(6.5rem+env(safe-area-inset-bottom)+0.75rem)] md:static md:px-0 md:pb-0">
  <div class="mx-auto max-w-3xl rounded-[1.5rem] border border-white/70 bg-white/90 px-4 py-3 shadow-lg shadow-slate-200/50 backdrop-blur md:mx-0 md:max-w-none md:border md:border-white/60 md:bg-white/80 md:shadow-md">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
      <% if local_assigns[:hint].present? %>
        <p class="text-sm text-slate-500"><%= hint %></p>
      <% end %>
      <%= yield %>
    </div>
  </div>
</div>
