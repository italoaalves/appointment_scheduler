<%# Renders a floating Hydro-Glass breadcrumb pill.
    Locals: crumbs — array of hashes: { label: "...", path: "..." }
    Last crumb has no path (current page).
    Desktop: parent + current visible; hover expands full path to the left.
    Mobile: parent + current visible; "..." button opens a Hydro-Glass bottom sheet. %>
<% return if local_assigns[:crumbs].blank? || crumbs.empty? %>

<%
  all_crumbs = Array(crumbs)
  current   = all_crumbs.last
  parent    = all_crumbs.length >= 2 ? all_crumbs[-2] : nil
  ancestors = all_crumbs.length > 2  ? all_crumbs[0..-3] : []
%>

<div data-controller="ui--breadcrumb">

  <%# ── Desktop floating pill ──────────────────────────────────── %>
  <div class="hidden sm:block fixed bottom-8 right-32 z-30">
    <nav aria-label="<%= t('breadcrumbs.label') %>"
         class="flex items-center px-3 py-1.5 rounded-full font-mono text-xs glass-subtle"
         data-action="mouseenter->ui--breadcrumb#expand mouseleave->ui--breadcrumb#collapse">

      <%# Ancestors — hidden by default, slide in on hover %>
      <% if ancestors.any? %>
        <span class="flex items-center overflow-hidden max-w-0 opacity-0 transition-all duration-200 ease-out"
              data-ui--breadcrumb-target="ancestors">
          <% ancestors.each do |crumb| %>
            <% if crumb[:path].present? %>
              <%= link_to crumb[:label], crumb[:path],
                  class: "text-slate-400 hover:text-slate-200 whitespace-nowrap transition-colors" %>
            <% else %>
              <span class="text-slate-400 whitespace-nowrap"><%= crumb[:label] %></span>
            <% end %>
            <span class="mx-2 text-slate-500">/</span>
          <% end %>
        </span>
      <% end %>

      <%# Parent %>
      <% if parent %>
        <% if parent[:path].present? %>
          <%= link_to parent[:label], parent[:path],
              class: "text-slate-400 hover:text-slate-200 whitespace-nowrap transition-colors" %>
        <% else %>
          <span class="text-slate-400 whitespace-nowrap"><%= parent[:label] %></span>
        <% end %>
        <span class="mx-2 text-slate-500">/</span>
      <% end %>

      <%# Current page %>
      <span class="text-cerulean font-medium whitespace-nowrap" aria-current="page">
        <%= current[:label] %>
      </span>
    </nav>
  </div>

  <%# ── Mobile floating pill ───────────────────────────────────── %>
  <div class="breadcrumbs__mobile sm:hidden fixed z-20"
       data-role="mobile-breadcrumbs">
    <nav aria-label="<%= t('breadcrumbs.label') %>"
         class="flex max-w-[8.5rem] min-w-0 items-center gap-1.5 rounded-[0.875rem] px-2.5 py-2 font-mono text-[11px] glass-subtle">

      <%# Collapsed ancestors — shown as "···" button %>
      <% if ancestors.any? %>
        <button type="button"
                class="shrink-0 text-slate-400 transition-colors leading-none hover:text-slate-200"
                data-action="click->ui--breadcrumb#openSheet"
                aria-label="<%= t('breadcrumbs.show_full_path') %>">···</button>
        <span class="shrink-0 text-slate-500">/</span>
      <% end %>

      <%# Parent %>
      <% if parent %>
        <% if parent[:path].present? %>
          <%= link_to parent[:label], parent[:path],
              class: "min-w-0 truncate text-slate-400 transition-colors hover:text-slate-200" %>
        <% else %>
          <span class="min-w-0 truncate text-slate-400"><%= parent[:label] %></span>
        <% end %>
        <span class="shrink-0 text-slate-500">/</span>
      <% end %>

      <%# Current page %>
      <span class="min-w-0 truncate text-cerulean font-medium" aria-current="page">
        <%= current[:label] %>
      </span>
    </nav>
  </div>

  <%# ── Mobile bottom sheet (full path) ───────────────────────── %>
  <% if ancestors.any? %>
    <%= render "shared/breadcrumb_sheet", crumbs: all_crumbs %>
  <% end %>

</div>
