<div class="booking-page">
  <%= render "booking/hero",
             eyebrow: t("booking.hero.eyebrow"),
             title: @space&.name || t("booking.state.shell_title"),
             subtitle: t("booking.state.shell_subtitle"),
             supporting_text: booking_business_type_label(@space),
             chips: booking_hero_chips(@space),
             details: @space&.address.presence %>

  <%= render "booking/state_card",
             title: t("booking.unavailable.title"),
             body: t("booking.unavailable.body"),
             next_step: t("booking.unavailable.next_step"),
             action_label: t("booking.state.back_home"),
             action_path: root_path %>
</div>
