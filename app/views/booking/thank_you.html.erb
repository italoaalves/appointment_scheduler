<div class="booking-page">
  <%= render "booking/hero",
             eyebrow: t("booking.hero.eyebrow"),
             title: t("booking.thank_you.title_new"),
             subtitle: t("booking.thank_you.subtitle"),
             supporting_text: @space.name,
             chips: booking_hero_chips(@space),
             details: @space.address.presence,
             extra_class: "booking-hero-sticky" %>

  <div class="booking-grid">
    <div class="order-2 lg:order-1">
      <%= render "shared/card", extra_class: "booking-composer" do %>
        <section data-role="booking-confirmation-card" class="space-y-6">
          <span class="status-pill status-pill-warning"><%= t("booking.thank_you.status_pending") %></span>

          <div class="space-y-2">
            <h2 class="text-xl font-semibold text-deep"><%= t("booking.thank_you.confirmation_title") %></h2>
            <p class="text-sm leading-6 text-slate-600"><%= t("booking.thank_you.confirmation_body") %></p>
          </div>

          <% if @appointment.present? %>
            <div class="flex flex-wrap gap-3">
              <%= link_to t("booking.thank_you.add_to_calendar"),
                          booking_calendar_ics_path(token: booking_calendar_token(@appointment)),
                          class: button_classes(:secondary),
                          download: "" %>

              <% google_calendar_url = @appointment.scheduled_at ? [
                "https://calendar.google.com/calendar/render?action=TEMPLATE",
                "&text=#{ERB::Util.url_encode("#{@space.name} — #{t("booking.calendar.summary_suffix")}")}",
                "&dates=#{@appointment.scheduled_at.utc.strftime("%Y%m%dT%H%M%SZ")}/#{(@appointment.scheduled_at + @appointment.effective_duration_minutes.minutes).utc.strftime("%Y%m%dT%H%M%SZ")}",
                @space.address.present? ? "&location=#{ERB::Util.url_encode(@space.address)}" : nil
              ].compact.join("") : nil %>

              <% if google_calendar_url.present? %>
                <a href="<%= google_calendar_url %>"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="<%= button_classes(:secondary) %>">
                  <%= t("booking.thank_you.add_to_google_calendar") %>
                </a>
              <% end %>
            </div>
          <% end %>

          <div class="booking-summary-callout">
            <p class="meta-label-strong"><%= t("booking.thank_you.message_title") %></p>
            <p class="mt-2 text-sm leading-6 text-slate-600">
              <%= @space.booking_success_message.presence || t("booking.thank_you.default_message") %>
            </p>
          </div>
        </section>
      <% end %>
    </div>

    <div class="order-1 lg:order-2">
      <%= render "booking/summary_card",
                 space: @space,
                 appointment: @appointment,
                 title: t("booking.summary.title"),
                 subtitle: t("booking.thank_you.summary_subtitle"),
                 status_label: (@appointment.present? ? t("booking.thank_you.status_pending") : nil) %>
    </div>
  </div>
</div>
