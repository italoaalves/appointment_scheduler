<%= render "application/shared/card", extra_class: "booking-state-card" do %>
  <section data-role="booking-state-card" class="space-y-4">
    <div class="space-y-2">
      <h2 class="font-display text-2xl font-extrabold tracking-tight text-deep"><%= title %></h2>
      <p class="text-sm leading-6 text-slate-600"><%= body %></p>
    </div>

    <% if local_assigns[:next_step].present? %>
      <p class="text-sm font-medium leading-6 text-slate-700"><%= next_step %></p>
    <% end %>

    <% if local_assigns[:action_label].present? && local_assigns[:action_path].present? %>
      <div class="pt-2">
        <%= link_to action_label,
                    action_path,
                    class: button_classes(:secondary, "w-full justify-center sm:w-auto") %>
      </div>
    <% end %>
  </section>
<% end %>
