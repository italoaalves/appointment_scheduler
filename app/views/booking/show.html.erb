<% booking_timezone = booking_timezone_name(@space) %>
<% today_in_space = Time.current.in_time_zone(booking_timezone).to_date %>
<% business_weekdays = @space.business_weekdays %>

<div class="booking-page"
     data-controller="booking"
     data-booking-slots-url-value="<%= @booking_context.slots_path %>"
     data-booking-business-weekdays-value="<%= business_weekdays.to_json %>"
     data-booking-timezone-value="<%= booking_timezone %>"
     data-booking-locale-value="<%= I18n.locale %>"
     data-booking-step-labels-value="<%= {
       current: t("booking.step_states.current"),
       complete: t("booking.step_states.complete"),
       locked: t("booking.step_states.up_next")
     }.to_json %>">
  <%= turbo_stream_from [ @space, :booking_slots ] %>

  <div class="booking-flow-shell booking-flow-shell-sidebar">
    <aside class="booking-flow-hero-rail booking-hero-sticky">
      <%= render "booking/hero",
                 eyebrow: t("booking.hero.eyebrow"),
                 title: @space.name,
                 subtitle: t("booking.hero.subtitle"),
                 supporting_text: booking_business_type_label(@space),
                 chips: booking_hero_chips(@space),
                 details: @space.address.presence,
                 mobile_collapsible: true,
                 compact_items: [
                   booking_availability_label(@space),
                   booking_duration_label(@space.slot_duration_minutes)
                 ],
                 extra_class: "booking-hero-sidebar" %>
    </aside>

    <div class="booking-flow-stage">
      <%= form_with url: @booking_context.form_url,
                    method: :post,
                    class: "booking-flow",
                    data: { role: "booking-composer" } do |form| %>
        <%= render "booking/composer",
                   form: form,
                   space: @space,
                   today_in_space: today_in_space,
                   booking_timezone: booking_timezone %>
        <%= render "booking/slot_sync", space: @space %>
      <% end %>
    </div>
  </div>
</div>
