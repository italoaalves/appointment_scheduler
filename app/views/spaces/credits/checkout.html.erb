<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.credits"), path: settings_credits_path },
  { label: t("billing.credits.checkout.title") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.billing_section"),
             title: t("billing.credits.checkout.title"),
             subtitle: t("billing.credits.checkout.subtitle"),
             statuses: [
               settings_intro_status(t("billing.credits.show.credits"), @bundle.amount.to_s, tone: :accent)
             ] %>

  <%= render "shared/settings_panel",
             title: t("billing.credits.checkout.summary"),
             description: t("billing.credits.checkout.summary_hint") do %>
    <div class="grid gap-4 lg:grid-cols-2">
      <div class="settings-info-tile">
        <p class="meta-label"><%= t("billing.credits.show.credits") %></p>
        <p class="mt-1 text-3xl font-bold text-deep"><%= @bundle.amount %></p>
      </div>
      <div class="settings-info-tile">
        <p class="meta-label"><%= t("billing.show.payment_amount") %></p>
        <p class="mt-1 text-2xl font-bold text-deep">
          <%= number_to_currency(@bundle.price_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
        </p>
      </div>
    </div>
  <% end %>

  <%= form_with url: settings_credits_path, method: :post, class: "space-y-6" do |f| %>
    <%= hidden_field_tag :bundle_id, @bundle.id %>

    <%= render "shared/settings_panel",
               title: t("billing.credits.checkout.payment_method"),
               description: t("billing.credits.checkout.payment_method_hint") do %>
      <div class="grid gap-3 xl:grid-cols-3">
        <% [
          ["pix", t("billing.checkout.pix")],
          ["credit_card", t("billing.checkout.credit_card")],
          ["boleto", t("billing.checkout.boleto")]
        ].each_with_index do |(value, label), i| %>
          <label class="settings-choice-card">
            <input type="radio" name="payment_method" value="<%= value %>"
                   <%= i == 0 ? "checked" : "" %>
                   class="h-4 w-4 accent-electric" />
            <span><%= label %></span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", hint: t("billing.credits.checkout.submit_hint") do %>
      <div class="checkout-action-row">
        <%= link_to settings_credits_path,
                    aria: { label: t("billing.credits.checkout.back") },
                    class: "#{button_classes(:secondary)} checkout-action-back" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 sm:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          <span class="hidden sm:inline"><%= t("billing.credits.checkout.back") %></span>
        <% end %>
        <button type="submit"
                class="<%= "#{button_classes(:primary)} checkout-action-confirm justify-center" %>"
                data-turbo-submits-with="<%= t("billing.credits.checkout.processing") %>">
          <span class="sm:hidden"><%= t("billing.credits.checkout.confirm_short") %></span>
          <span class="hidden sm:inline"><%= t("billing.credits.checkout.confirm") %></span>
        </button>
      </div>
    <% end %>
  <% end %>
</div>
