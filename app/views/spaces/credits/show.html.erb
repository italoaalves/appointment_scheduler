<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.credits") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>
<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.billing_section"),
             title: t("billing.credits.show.title"),
             subtitle: t("billing.credits.show.subtitle"),
             statuses: [
               settings_intro_status(t("billing.credits.show.balance_title"), (@credit&.balance || 0).to_s, tone: :accent),
               (@subscription&.plan&.feature?(:whatsapp_included_quota) ? settings_intro_status(t("billing.credits.show.monthly_quota"), (@credit&.monthly_quota_remaining || 0).to_s, tone: :neutral) : nil)
             ] %>

  <% if @pending_purchases.any? %>
    <%= render "shared/settings_panel",
               title: t("billing.credits.show.pending_purchases"),
               description: t("billing.credits.show.pending_purchases_hint") do %>
      <div class="space-y-3">
        <% @pending_purchases.each do |purchase| %>
          <div class="settings-info-tile flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div class="space-y-1">
              <p class="text-sm font-semibold text-deep"><%= purchase.amount %> <%= t("billing.credits.show.credits") %></p>
              <p class="text-xs text-slate-500"><%= l(purchase.created_at, format: :long) %></p>
            </div>

            <div class="flex flex-wrap gap-2">
              <% if purchase.pix_qr_code_base64.present? %>
                <%= link_to t("billing.credits.show.view_qr_code"),
                            payment_settings_credits_path(purchase_id: purchase.id),
                            class: button_classes(:primary, "btn-sm") %>
              <% elsif purchase.bank_slip_url.present? %>
                <%= link_to t("billing.credits.show.view_boleto"),
                            purchase.bank_slip_url,
                            target: "_blank",
                            rel: "noopener noreferrer",
                            class: button_classes(:secondary, "btn-sm") %>
              <% elsif purchase.invoice_url.present? %>
                <%= link_to t("billing.credits.show.pay_now"),
                            purchase.invoice_url,
                            target: "_blank",
                            rel: "noopener noreferrer",
                            class: button_classes(:primary, "btn-sm") %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <% if @pending_purchases.any? { |p| p.bank_slip_url.present? } %>
        <p class="text-xs text-slate-500"><%= t("billing.credits.boleto_clearing_warning") %></p>
      <% end %>
    <% end %>
  <% end %>

  <%= render "shared/settings_panel",
             title: t("billing.credits.show.purchase_title"),
             description: t("billing.credits.show.purchase_hint") do %>
    <div class="grid gap-4 xl:grid-cols-3">
      <% @bundles.each do |bundle| %>
        <%= render "shared/card",
                   extra_class: "h-full rounded-card p-4 text-center" do %>
          <div class="flex h-full flex-col">
            <p class="text-3xl font-bold text-deep"><%= bundle.amount %></p>
            <p class="mt-1 text-sm text-slate-500"><%= t("billing.credits.show.credits") %></p>
            <p class="mt-2 text-sm font-medium text-slate-700"><%= number_to_currency(bundle.price_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %></p>
            <%= link_to t("billing.credits.show.purchase"),
                        checkout_settings_credits_path(bundle_id: bundle.id),
                        class: "mt-4 w-full #{button_classes(:primary)}" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @events.any? %>
    <%= render "shared/settings_panel",
               title: t("billing.credits.show.history_title"),
               description: t("billing.credits.show.history_hint") do %>
      <div class="space-y-3">
        <% @events.each do |event| %>
          <div class="settings-info-tile flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
            <span class="text-sm font-medium text-deep"><%= billing_event_label(event.event_type) %></span>
            <span class="text-xs text-slate-500"><%= l(event.created_at, format: :long) %></span>
          </div>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <%= render "shared/empty_state", content: t("billing.credits.show.no_history") %>
  <% end %>
</div>
