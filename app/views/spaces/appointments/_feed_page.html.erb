<% tz = TimezoneResolver.zone(current_tenant) %>
<% today = Time.current.in_time_zone(tz).to_date %>
<% day_names   = t("date.day_names") %>
<% month_names = t("date.month_names") %>
<% abbr_months = t("date.abbr_month_names") %>

<% if grouped_appointments.any? %>
  <div class="space-y-8">
    <% grouped_appointments.each do |date, appts| %>
      <div>
        <div class="sticky card-glass  z-10 -mx-1 my-6 px-2 py-1 mb-3" style="top: 111px;">
          <h2 class="font-display font-bold text-deep text-lg mt-2 p-2">
            <% if date.nil? %>
              <%= t("space.appointments.feed.unscheduled") %>
            <% elsif date == today %>
              <%= t("space.appointments.feed.today") %>
            <% elsif date == today + 1 %>
              <%= t("space.appointments.feed.tomorrow") %>
            <% elsif date == today - 1 %>
              <%= t("space.appointments.feed.yesterday") %>
            <% elsif (date - today).abs < 7 %>
              <%= day_names[date.wday] %>
            <% else %>
              <%= "#{month_names[date.month]} #{date.day}" %>
            <% end %>
            <% if date %>
              <span class="ml-2 text-sm font-normal text-slate-400">
                <%= "#{date.day} #{abbr_months[date.month]} #{date.year}" %>
              </span>
            <% end %>
          </h2>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          <% appts.each do |appointment| %>
            <%= render "appointment", appointment: appointment %>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if appointments.next_page %>
      <turbo-frame id="appointments-page-<%= appointments.next_page %>"
                   src="<%= appointments_path(page: appointments.next_page, status: params[:status], date_from: params[:date_from], date_to: params[:date_to]) %>"
                   loading="lazy">
        <%= render "skeleton_loaders" %>
      </turbo-frame>
    <% end %>
  </div>
<% else %>
  <%= render "application/shared/empty_state", content: t("space.appointments.index.empty") %>
<% end %>
