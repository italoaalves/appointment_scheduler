<% today      = Time.current.in_time_zone(tz).to_date %>
<% day_names   = t("date.day_names") %>
<% month_names = t("date.month_names") %>
<% abbr_months = t("date.abbr_month_names") %>

<% grouped_appointments.each do |date, appts| %>
  <div>
    <%
      date_title = if date.nil?
        t("space.appointments.feed.unscheduled")
      elsif date == today
        t("space.appointments.feed.today")
      elsif date == today + 1
        t("space.appointments.feed.tomorrow")
      elsif date == today - 1
        t("space.appointments.feed.yesterday")
      elsif (date - today).abs < 7
        day_names[date.wday]
      else
        "#{month_names[date.month]} #{date.day}"
      end
      date_subtitle = date ? "#{date.day} #{abbr_months[date.month]} #{date.year}" : nil
    %>
    <%= render "application/shared/sticky_section", title: date_title, subtitle: date_subtitle %>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <% appts.each do |appointment| %>
        <%= render "appointment", appointment: appointment %>
      <% end %>
    </div>
  </div>
<% end %>
