<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.appointments"), path: appointments_path },
  { label: @appointment.customer&.name || "—" }
] } %>
<div class="space-y-4">
  <header class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        <%= t("space.appointments.show.title") %>
      </h1>
      <p class="mt-1 text-xs text-slate-600">
        <%= t("space.appointments.show.subtitle") %>
      </p>
    </div>
    <%= render "show_status", appointment: @appointment %>
  </header>

  <div class="panel-card-compact">
    <dl class="detail-list">
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.customer") %></dt>
        <dd class="detail-list__value">
          <%= @appointment.customer&.name || "—" %>
        </dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.scheduled_for") %></dt>
        <dd class="detail-list__value">
          <%= format_appointment_time(@appointment.scheduled_at, space: @appointment.space, format: :long) || "—" %>
        </dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.requested_at") %></dt>
        <dd class="detail-list__value">
          <%= format_appointment_time(@appointment.requested_at, space: @appointment.space, format: :date_only) || "—" %>
        </dd>
      </div>
      <% if @appointment.finished? && @appointment.finished_at.present? %>
        <div class="detail-list__row">
          <dt class="detail-list__term"><%= t("space.appointments.show.finished_at") %></dt>
          <dd class="detail-list__value">
            <%= format_appointment_time(@appointment.finished_at, space: @appointment.space, format: :long) || "—" %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <%= render "show_actions", appointment: @appointment %>
</div>
