<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.appointments"), path: appointments_path },
  { label: @appointment.customer&.name || "—" }
] } %>
<div class="space-y-4">
  <header class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        <%= t("space.appointments.show.title") %>
      </h1>
      <p class="mt-1 text-xs text-slate-600">
        <%= t("space.appointments.show.subtitle") %>
      </p>
    </div>
    <%= render "shared/status_badge", status: @appointment.status %>
  </header>

  <div class="panel-card-compact">
    <dl class="detail-list">
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.customer") %></dt>
        <dd class="detail-list__value">
          <%= @appointment.customer&.name || "—" %>
        </dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.scheduled_for") %></dt>
        <dd class="detail-list__value">
          <%= format_appointment_time(@appointment.scheduled_at, space: @appointment.space, format: :long) || "—" %>
        </dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.appointments.show.requested_at") %></dt>
        <dd class="detail-list__value">
          <%= format_appointment_time(@appointment.requested_at, space: @appointment.space, format: :date_only) || "—" %>
        </dd>
      </div>
      <% if @appointment.finished? && @appointment.finished_at.present? %>
        <div class="detail-list__row">
          <dt class="detail-list__term"><%= t("space.appointments.show.finished_at") %></dt>
          <dd class="detail-list__value">
            <%= format_appointment_time(@appointment.finished_at, space: @appointment.space, format: :long) || "—" %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <% unless @appointment.cancelled? %>
      <%= link_to t("space.appointments.show.edit_reschedule"), edit_appointment_path(@appointment), class: button_classes(:primary) unless @appointment.rescheduled_from.present? %>
    <% end %>

    <% if @appointment.pending? %>
      <%= button_to t("space.appointments.index.confirm"), confirm_appointment_path(@appointment), method: :patch, class: button_classes(:success) %>
    <% end %>

    <% if @appointment.confirmed? %>
      <% if @appointment.scheduled_in_past? %>
        <%= button_to t("space.appointments.index.no_show"), no_show_appointment_path(@appointment), method: :patch, data: { turbo_confirm: t("space.appointments.index.no_show_confirm") }, class: button_classes(:neutral) %>
      <% end %>
      <% if @appointment.scheduled_in_past? %>
        <%= link_to t("space.appointments.index.finish"), finish_form_appointment_path(@appointment), class: button_classes(:success) %>
      <% end %>
    <% end %>
    <% if @appointment.pending? || @appointment.confirmed? %>
      <%= button_to t("space.appointments.index.cancel"), cancel_appointment_path(@appointment), method: :patch, data: { turbo_confirm: t("space.appointments.index.cancel_confirm") }, class: button_classes(:cancel) %>
    <% end %>

    <% if current_user.can?(:destroy_appointments) %>
      <%= button_to t("space.appointments.index.delete"), appointment_path(@appointment), method: :delete, data: { turbo_confirm: t("space.appointments.index.delete_confirm"), turbo_submits_with: t("shared.deleting") }, class: button_classes(:danger) %>
    <% end %>
  </div>
</div>
