<% content_for(:wide_layout) { "" } %>
<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.appointments") }
] } %>

<% if turbo_frame_request? %>
  <% frame_id = request.headers["Turbo-Frame"] %>
  <turbo-frame id="<%= frame_id %>">
    <% if frame_id == "appointments-feed" %>
      <%# Filter refresh — rebuild past loader + feed list inside the frame %>
      <%= render "past_loader",
            before_date: params[:date_from].presence || Date.current.iso8601,
            page: 1,
            status: params[:status] %>
      <div id="appointments-feed-list" class="space-y-8" style="overflow-anchor: auto;">
        <%= render "feed_page", grouped_appointments: @grouped_appointments, appointments: @appointments %>
      </div>
    <% else %>
      <%# Lazy pagination (appointments-page-N) — raw feed page inside its own frame %>
      <%= render "feed_page", grouped_appointments: @grouped_appointments, appointments: @appointments %>
    <% end %>
  </turbo-frame>
<% else %>
  <div class="space-y-6" data-controller="sticky-stack">
    <% page_actions = capture do %>
      <%= link_to t("space.appointments.index.new_button"), new_appointment_path, class: button_classes(:primary) %>
    <% end %>
    <%= render "shared/page_header", title: t("space.appointments.index.title"), actions: page_actions %>

    <%= form_with url: appointments_path,
                  method: :get,
                  local: true,
                  data: { turbo_frame: "appointments-feed", sticky_stack_target: "filter" },
                  class: "card-glass sticky-filter flex flex-wrap items-end gap-3 p-4" do %>
      <div class="flex flex-col gap-1">
        <label for="status" class="<%= form_label_classes_sm %>"><%= t("space.appointments.filters.status") %></label>
        <%= select_tag :status,
                       options_for_select(
                         [
                           [ t("space.appointments.filters.all_statuses"), "" ],
                           [ t("space.appointments.filters.pending"), "pending" ],
                           [ t("space.appointments.filters.confirmed"), "confirmed" ],
                           [ t("space.appointments.filters.cancelled"), "cancelled" ],
                           [ t("space.appointments.filters.rescheduled"), "rescheduled" ],
                           [ t("space.appointments.filters.no_show"), "no_show" ],
                           [ t("space.appointments.filters.finished"), "finished" ]
                         ],
                         params[:status]
                       ),
                       class: "form-input-sm" %>
      </div>
      <div class="flex flex-col gap-1">
        <label for="date_from" class="<%= form_label_classes_sm %>"><%= t("space.appointments.filters.from") %></label>
        <%= date_field_tag :date_from, params[:date_from], class: "form-input-sm" %>
      </div>
      <div class="flex flex-col gap-1">
        <label for="date_to" class="<%= form_label_classes_sm %>"><%= t("space.appointments.filters.to") %></label>
        <%= date_field_tag :date_to, params[:date_to], class: "form-input-sm" %>
      </div>
      <div class="flex gap-2">
        <%= submit_tag t("space.appointments.filters.apply"), class: button_classes(:primary), data: { turbo_submits_with: t("shared.submitting") } %>
        <%= link_to t("space.appointments.filters.clear"), appointments_path, class: button_classes(:secondary), data: { turbo_frame: "appointments-feed" } %>
      </div>
    <% end %>

    <turbo-frame id="appointments-feed"
                 data-controller="infinite-scroll past-loader"
                 data-past-loader-url-value="<%= appointments_path %>">
      <%= render "past_loader",
            before_date: params[:date_from].presence || Date.current.iso8601,
            page: 1,
            status: params[:status] %>
      <div id="appointments-feed-list" class="space-y-8" style="overflow-anchor: auto;">
        <%= render "feed_page", grouped_appointments: @grouped_appointments, appointments: @appointments %>
      </div>
    </turbo-frame>
  </div>
<% end %>
