<% tz = TimezoneResolver.zone(appointment.space) %>
<% in_progress = appointment.confirmed? &&
     appointment.scheduled_at.present? &&
     appointment.scheduled_at <= Time.current &&
     Time.current <= appointment.scheduled_at + appointment.effective_duration_minutes.minutes %>

<div id="<%= dom_id(appointment) %>"
     class="appointment-card group relative overflow-hidden rounded-card <%= in_progress ? 'card-active' : '' %>"
     data-controller="swipe-actions">

  <%# Action drawer — right edge on touch (swipe), bottom edge on hover devices %>
  <div data-swipe-actions-target="actions"
       class="absolute right-0 top-0 h-full w-28 grid grid-cols-2 place-content-center gap-1.5 px-3
              bg-gradient-to-l from-white via-white/90 to-white/60
              can-hover:top-auto can-hover:bottom-0 can-hover:left-0 can-hover:w-full can-hover:h-auto
              can-hover:flex can-hover:flex-row can-hover:justify-end can-hover:px-3 can-hover:py-2
              can-hover:bg-gradient-to-t can-hover:from-white can-hover:via-white/90 can-hover:to-white/60
              z-[3] opacity-0 transition-[opacity,translate] duration-[250ms] ease-[cubic-bezier(0,0,0.2,1)]"
       role="group"
       aria-label="<%= t("space.appointments.index.table.actions") %>">
    <% if appointment.pending? %>
      <%= button_to confirm_appointment_path(appointment),
            method: :patch,
            params: { source: "index" },
            class: "flex flex-col items-center gap-0.5 p-3 can-hover:p-2 rounded-lg text-emerald-500 hover:bg-emerald-100 hover:text-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-400 cursor-pointer",
            data: { swipe_action: "" },
            aria: { label: t("space.appointments.index.confirm") } do %>
        <svg class="w-5 h-5 can-hover:w-4 can-hover:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      <% end %>
    <% end %>
    <% if appointment.confirmed? && appointment.scheduled_in_past? %>
      <%= link_to finish_form_appointment_path(appointment),
            class: "flex flex-col items-center gap-0.5 p-3 can-hover:p-2 rounded-lg text-emerald-500 hover:bg-emerald-100 hover:text-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-400",
            data: { turbo_frame: "_top", swipe_action: "" },
            aria: { label: t("space.appointments.index.finish") } do %>
        <svg class="w-5 h-5 can-hover:w-4 can-hover:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      <% end %>
      <%= button_to no_show_appointment_path(appointment),
            method: :patch,
            params: { source: "index" },
            data: { turbo_confirm: t("space.appointments.index.no_show_confirm"), swipe_action: "" },
            class: "flex flex-col items-center gap-0.5 p-3 can-hover:p-2 rounded-lg text-slate-400 hover:bg-slate-100 hover:text-slate-600 focus:outline-none focus:ring-2 focus:ring-slate-400 cursor-pointer",
            aria: { label: t("space.appointments.index.no_show") } do %>
        <svg class="w-5 h-5 can-hover:w-4 can-hover:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      <% end %>
    <% end %>
    <% if appointment.pending? || appointment.confirmed? %>
      <%= button_to cancel_appointment_path(appointment),
            method: :patch,
            params: { source: "index" },
            data: { turbo_confirm: t("space.appointments.index.cancel_confirm"), swipe_action: "" },
            class: "flex flex-col items-center gap-0.5 p-3 can-hover:p-2 rounded-lg text-amber-500 hover:bg-amber-100 hover:text-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-400 cursor-pointer",
            aria: { label: t("space.appointments.index.cancel") } do %>
        <svg class="w-5 h-5 can-hover:w-4 can-hover:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    <% end %>
    <% if current_user.can?(:destroy_appointments) %>
      <%= button_to appointment_path(appointment),
            method: :delete,
            params: { source: "index" },
            data: { turbo_confirm: t("space.appointments.index.delete_confirm"), turbo_submits_with: t("shared.deleting"), swipe_action: "" },
            class: "flex flex-col items-center gap-0.5 p-3 can-hover:p-2 rounded-lg text-red-400 hover:bg-red-100 hover:text-red-700 focus:outline-none focus:ring-2 focus:ring-red-400 cursor-pointer",
            aria: { label: t("space.appointments.index.delete") } do %>
        <svg class="w-5 h-5 can-hover:w-4 can-hover:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>
    <% end %>
  </div>

  <%# Card content — stays in place; action panel overlays on top %>
  <div data-swipe-actions-target="content"
       class="card-glass relative z-[2] h-full">

    <%# Tappable info area — navigates to appointment detail %>
    <%= link_to appointment_path(appointment),
          class: "block p-4 cursor-pointer",
          data: { turbo_frame: "_top" } do %>
      <%# Top row: time + status badge %>
      <div class="flex items-start justify-between mb-2">
        <p class="font-display font-bold text-deep text-xl leading-none">
          <%= appointment.scheduled_at ? appointment.scheduled_at.in_time_zone(tz).strftime("%-I:%M %p") : "—" %>
        </p>
        <%= render "application/shared/status_badge", status: appointment.status %>
      </div>

      <%# Customer name %>
      <p class="font-body font-medium text-deep/90 text-base leading-snug">
        <%= appointment.customer&.name || "—" %>
      </p>

      <%# Duration + in-progress indicator %>
      <p class="font-body text-sm text-slate-500 mt-0.5 flex items-center gap-1.5">
        <%= t("space.appointments.index.duration_minutes", count: appointment.effective_duration_minutes) %>
        <% if in_progress %>
          <span class="inline-flex items-center gap-1 text-cerulean font-medium">
            <span class="w-1.5 h-1.5 rounded-full bg-cerulean animate-pulse" aria-hidden="true"></span>
            <%= t("space.appointments.index.in_progress") %>
          </span>
        <% end %>
      </p>
    <% end %>

    <%# Touch: swipe hint (hidden on pointer devices) — shown whenever the drawer has at least one action %>
    <% if appointment.pending? || appointment.confirmed? || current_user.can?(:destroy_appointments) %>
      <div data-swipe-actions-target="hint" class="can-hover:hidden px-4 pb-3 flex justify-end transition-opacity duration-[200ms]">
        <span class="text-xs text-slate-400"><%= t("space.appointments.index.swipe_hint") %></span>
      </div>
    <% end %>
  </div>
</div>
