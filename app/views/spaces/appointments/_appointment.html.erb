<% tz = TimezoneResolver.zone(appointment.space) %>
<% in_progress = appointment.confirmed? &&
     appointment.scheduled_at.present? &&
     appointment.scheduled_at <= Time.current &&
     Time.current <= appointment.scheduled_at + appointment.effective_duration_minutes.minutes %>

<div id="<%= dom_id(appointment) %>"
     class="appointment-card group relative overflow-hidden rounded-card <%= in_progress ? 'card-active' : '' %>"
     data-controller="swipe-actions">

  <%# Mobile swipe-reveal action panel — hidden behind card, revealed by left swipe %>
  <div data-swipe-actions-target="actions"
       class="absolute right-0 top-0 h-full w-32 flex items-center justify-center gap-2 px-3
              bg-gradient-to-l from-deep/10 to-transparent opacity-0 transition-opacity duration-200 z-0">
    <%= link_to appointment_path(appointment),
          class: "flex flex-col items-center gap-0.5 p-2 rounded-lg bg-white/90 text-deep shadow-sm hover:bg-white focus:outline-none focus:ring-2 focus:ring-electric",
          tabindex: "0",
          aria: { label: t("space.appointments.index.view") } do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
      </svg>
    <% end %>
    <% if appointment.pending? || appointment.confirmed? %>
      <%= button_to cancel_appointment_path(appointment),
            method: :patch,
            params: { source: "index" },
            data: { turbo_confirm: t("space.appointments.index.cancel_confirm") },
            class: "flex flex-col items-center gap-0.5 p-2 rounded-lg bg-amber-100 text-amber-700 shadow-sm hover:bg-amber-200 focus:outline-none focus:ring-2 focus:ring-amber-400 cursor-pointer",
            aria: { label: t("space.appointments.index.cancel") } do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    <% end %>
  </div>

  <%# Card content — slides left on mobile swipe %>
  <div data-swipe-actions-target="content"
       class="card-glass relative z-10 p-4 transition-transform duration-300 ease-out">

    <%# Top row: time + status badge %>
    <div class="flex items-start justify-between mb-2">
      <p class="font-display font-bold text-deep text-xl leading-none">
        <%= appointment.scheduled_at ? appointment.scheduled_at.in_time_zone(tz).strftime("%-I:%M %p") : "—" %>
      </p>
      <%= render "application/shared/status_badge", status: appointment.status %>
    </div>

    <%# Customer name %>
    <p class="font-body font-medium text-deep/90 text-base leading-snug">
      <%= appointment.customer&.name || "—" %>
    </p>

    <%# Duration + in-progress indicator %>
    <p class="font-body text-sm text-slate-500 mt-0.5 flex items-center gap-1.5">
      <%= t("space.appointments.index.duration_minutes", count: appointment.effective_duration_minutes) %>
      <% if in_progress %>
        <span class="inline-flex items-center gap-1 text-cerulean font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-cerulean animate-pulse" aria-hidden="true"></span>
          <%= t("space.appointments.index.in_progress") %>
        </span>
      <% end %>
    </p>

    <%# Desktop hover-revealed action strip %>
    <div class="hidden md:flex flex-wrap gap-1.5 mt-3 pt-3 border-t border-white/30
                opacity-0 group-hover:opacity-100 transition-opacity duration-200"
         role="group"
         aria-label="<%= t("space.appointments.index.table.actions") %>">
      <%= link_to t("space.appointments.index.view"), appointment_path(appointment),
            class: button_classes(:table_link), tabindex: "0" %>
      <% unless appointment.cancelled? || appointment.rescheduled_from.present? %>
        <%= link_to t("space.appointments.index.edit"), edit_appointment_path(appointment),
              class: button_classes(:table_link), tabindex: "0" %>
      <% end %>
      <% if appointment.pending? %>
        <%= button_to t("space.appointments.index.confirm"), confirm_appointment_path(appointment),
              method: :patch, params: { source: "index" },
              class: button_classes(:table_success) %>
      <% end %>
      <% if appointment.confirmed? && appointment.scheduled_in_past? %>
        <%= button_to t("space.appointments.index.no_show"), no_show_appointment_path(appointment),
              method: :patch, params: { source: "index" },
              data: { turbo_confirm: t("space.appointments.index.no_show_confirm") },
              class: button_classes(:table_muted) %>
        <%= link_to t("space.appointments.index.finish"), finish_form_appointment_path(appointment),
              class: button_classes(:table_success) %>
      <% end %>
      <% if appointment.pending? || appointment.confirmed? %>
        <%= button_to t("space.appointments.index.cancel"), cancel_appointment_path(appointment),
              method: :patch, params: { source: "index" },
              data: { turbo_confirm: t("space.appointments.index.cancel_confirm") },
              class: button_classes(:table_cancel) %>
      <% end %>
      <% if current_user.can?(:destroy_appointments) %>
        <%= button_to t("space.appointments.index.delete"), appointment_path(appointment),
              method: :delete, params: { source: "index" },
              data: { turbo_confirm: t("space.appointments.index.delete_confirm"), turbo_submits_with: t("shared.deleting") },
              class: button_classes(:table_danger) %>
      <% end %>
    </div>

    <%# Mobile: visible link + swipe hint %>
    <div class="md:hidden mt-3 pt-3 border-t border-white/30 flex items-center justify-between">
      <%= link_to t("space.appointments.index.view"), appointment_path(appointment),
            class: "text-sm text-electric font-medium focus:outline-none focus:underline" %>
      <span class="text-xs text-slate-400"><%= t("space.appointments.index.swipe_hint") %></span>
    </div>
  </div>
</div>
