<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.appointments"), path: appointments_path },
  { label: t("breadcrumbs.new") }
] } %>
<div class="space-y-6">
  <%= render "shared/page_header",
             title: t("space.appointments.new.title"),
             subtitle: t("space.appointments.new.subtitle") %>

  <div class="card-solid">
    <%= form_with model: @appointment, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :customer_id,
                       t("space.appointments.new.customer_label"),
                       class: form_label_classes %>
        <div class="mt-1">
          <%= form.collection_select :customer_id,
                                     current_tenant.customers.order(:name),
                                     :id, :name,
                                     { prompt: t("space.appointments.new.customer_prompt") },
                                     class: form_input_classes %>
        </div>
      </div>

      <div>
        <%= form.label :scheduled_at,
                       t("space.appointments.new.scheduled_for"),
                       class: form_label_classes %>
        <div class="mt-1 inline-flex items-center rounded-card border border-slate-300 bg-white px-3 py-2 text-sm text-deep">
          <% Time.use_zone(timezone_for(current_tenant)) do %>
            <%= form.datetime_select :scheduled_at,
                                     { start_year: Date.current.year },
                                     { class: "text-sm" } %>
          <% end %>
        </div>
      </div>

      <div>
        <%= form.label :status,
                       t("space.appointments.new.status_label"),
                       class: form_label_classes %>
        <div class="mt-1">
          <%= form.select :status,
                          Appointment.statuses.keys.map { |s| [t("activerecord.attributes.appointment.status.#{s}"), s] },
                          {},
                          class: form_input_classes %>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <%= form.submit t("space.appointments.new.submit"),
                        class: button_classes(:primary),
                        data: { turbo_submits_with: t("shared.submitting") } %>
      </div>
    <% end %>
  </div>
</div>
