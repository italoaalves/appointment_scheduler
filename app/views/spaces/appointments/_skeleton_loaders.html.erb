<div class="space-y-8" aria-hidden="true">
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <% 3.times do %>
      <div class="rounded-card card p-4 animate-pulse">
        <div class="flex items-start justify-between mb-2">
          <div class="h-7 w-20 bg-slate-200/70 rounded-md"></div>
          <div class="h-5 w-16 bg-slate-200/70 rounded-full"></div>
        </div>
        <div class="h-4 w-32 bg-slate-200/70 rounded mt-2"></div>
        <div class="h-3 w-16 bg-slate-200/70 rounded mt-2"></div>
        <div class="mt-3 pt-3 border-t border-white/30 flex gap-2">
          <div class="h-7 w-12 bg-slate-200/70 rounded-lg"></div>
          <div class="h-7 w-14 bg-slate-200/70 rounded-lg"></div>
        </div>
      </div>
    <% end %>
  </div>
</div>
