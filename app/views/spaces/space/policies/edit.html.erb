<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.policies") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.business"),
             title: t("space.policies.edit.title"),
             subtitle: t("space.policies.edit.subtitle"),
             statuses: [
               settings_intro_status(t("space.settings.edit.policies_title"), settings_policy_summary(@space), tone: :accent)
             ] %>

  <%= form_with model: @space, url: settings_space_policies_path, method: :patch, class: "space-y-6" do |form| %>
    <%= render "shared/error_messages", resource: @space %>

    <%= render "shared/settings_panel",
               title: t("space.policies.edit.cancellation_title"),
               description: t("space.policies.edit.cancellation_hint") do %>
      <div>
        <%= form.label :cancellation_min_hours_before, t("space.policies.edit.cancellation_label"), class: form_label_classes %>
        <%= form.number_field :cancellation_min_hours_before,
                              min: 0,
                              placeholder: t("space.policies.edit.no_restriction_placeholder"),
                              class: form_input_classes("max-w-xs") %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.policies.edit.reschedule_title"),
               description: t("space.policies.edit.reschedule_hint") do %>
      <div>
        <%= form.label :reschedule_min_hours_before, t("space.policies.edit.reschedule_label"), class: form_label_classes %>
        <%= form.number_field :reschedule_min_hours_before,
                              min: 0,
                              placeholder: t("space.policies.edit.no_restriction_placeholder"),
                              class: form_input_classes("max-w-xs") %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.policies.edit.requesting_title"),
               description: t("space.policies.edit.request_min_hint") do %>
      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :request_max_days_ahead, t("space.policies.edit.request_max_label"), class: form_label_classes %>
          <%= form.number_field :request_max_days_ahead,
                                min: 0,
                                placeholder: t("space.policies.edit.no_restriction_placeholder"),
                                class: form_input_classes %>
          <p class="mt-1.5 text-xs text-slate-500"><%= t("space.policies.edit.request_max_hint") %></p>
        </div>
        <div>
          <%= form.label :request_min_hours_ahead, t("space.policies.edit.request_min_label"), class: form_label_classes %>
          <%= form.number_field :request_min_hours_ahead,
                                min: 0,
                                placeholder: t("space.policies.edit.no_restriction_placeholder"),
                                class: form_input_classes %>
          <p class="mt-1.5 text-xs text-slate-500"><%= t("space.policies.edit.request_min_hint") %></p>
        </div>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", hint: settings_policy_summary(@space) do %>
        <%= form.submit t("space.policies.edit.submit"),
                        class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                        data: { turbo_submits_with: t("shared.submitting") } %>
    <% end %>
  <% end %>
</div>
