<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.space") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.business"),
             title: t("space.settings.edit.title"),
             subtitle: t("space.settings.edit.subtitle"),
             statuses: [
               settings_intro_status(t("space.settings.edit.availability_title"), settings_availability_summary(@space), tone: (@space.availability_configured? ? :success : :warning)),
               settings_intro_status(t("settings.sidebar.whatsapp"), settings_whatsapp_summary(@space), tone: (@space.whatsapp_phone_number&.active? ? :success : :neutral))
             ] %>

  <%= form_with model: @space, url: settings_space_path, method: :patch, class: "space-y-6" do |form| %>
    <%= render "shared/error_messages", resource: @space %>

    <%= render "shared/settings_panel",
               title: t("space.settings.edit.basic_info"),
               description: t("settings.sidebar.descriptions.space") do %>
      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :name, t("space.settings.edit.name_label"), class: form_label_classes %>
          <%= form.text_field :name, required: true, class: form_input_classes %>
        </div>
        <div>
          <%= form.label :business_type, t("space.settings.edit.business_type_label"), class: form_label_classes %>
          <%= form.text_field :business_type,
                              placeholder: t("space.settings.edit.business_type_placeholder"),
                              class: form_input_classes %>
        </div>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.settings.edit.contact"),
               description: t("space.settings.edit.subtitle") do %>
      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :address, t("space.settings.edit.address_label"), class: form_label_classes %>
          <%= form.text_area :address, rows: 3, class: form_input_classes %>
        </div>
        <div class="space-y-4">
          <div>
            <%= form.label :phone, t("space.settings.edit.phone_label"), class: form_label_classes %>
            <%= form.telephone_field :phone, class: form_input_classes %>
          </div>
          <div>
            <%= form.label :email, t("space.settings.edit.email_label"), class: form_label_classes %>
            <%= form.email_field :email, class: form_input_classes %>
          </div>
        </div>
      </div>

      <div class="grid gap-4 lg:grid-cols-2">
        <div>
          <%= form.label :instagram_url, t("space.settings.edit.instagram_label"), class: form_label_classes %>
          <%= form.url_field :instagram_url,
                             placeholder: "https://instagram.com/...",
                             class: form_input_classes %>
        </div>
        <div>
          <%= form.label :facebook_url, t("space.settings.edit.facebook_label"), class: form_label_classes %>
          <%= form.url_field :facebook_url,
                             placeholder: "https://facebook.com/...",
                             class: form_input_classes %>
        </div>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.settings.edit.banner_title"),
               description: t("space.settings.edit.banner_description") do %>
      <div class="space-y-4">
        <div class="overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
          <% if @space.banner_file.present? %>
            <%= image_tag settings_space_banner_path,
                          alt: t("space.settings.edit.banner_alt", name: @space.name),
                          class: "h-40 w-full object-cover" %>
          <% else %>
            <div class="flex h-40 w-full items-center justify-center px-6 text-center text-sm text-slate-500">
              <%= t("space.settings.edit.banner_empty") %>
            </div>
          <% end %>
        </div>

        <div>
          <%= form.label :banner_upload, t("space.settings.edit.banner_label"), class: form_label_classes %>
          <%= form.file_field :banner_upload,
                              accept: "image/png,image/jpeg,image/webp",
                              class: "mt-2 block w-full text-sm text-slate-600 file:mr-3 file:rounded-md file:border-0 file:bg-slate-900 file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:bg-slate-800" %>
          <p class="mt-1.5 text-xs text-slate-500"><%= t("space.settings.edit.banner_hint") %></p>
        </div>

        <% if @space.banner_file.present? %>
          <%= link_to t("space.settings.edit.banner_remove"),
                      settings_space_banner_path,
                      class: "#{button_classes(:secondary)} w-full justify-center sm:w-auto",
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: t("space.settings.edit.banner_remove_confirm")
                      } %>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.settings.edit.booking_success_message_label"),
               description: t("space.settings.edit.booking_success_message_hint") do %>
      <div>
        <%= form.label :booking_success_message, t("space.settings.edit.booking_success_message_label"), class: form_label_classes %>
        <%= form.text_area :booking_success_message,
                           rows: 4,
                           placeholder: t("space.settings.edit.booking_success_message_placeholder"),
                           class: form_input_classes %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("space.settings.edit.scheduling"),
               description: t("settings.sidebar.subtitle") do %>
      <div class="grid gap-4">
        <%= render "shared/settings_link_card",
                   path: edit_settings_space_availability_path,
                   title: t("space.settings.edit.availability_title"),
                   description: t("space.settings.edit.availability_link_hint"),
                   summary: settings_availability_summary(@space),
                   badge: @space.timezone.presence %>

        <% if current_user.can?(:manage_policies, space: @space) %>
          <%= render "shared/settings_link_card",
                     path: edit_settings_space_policies_path,
                     title: t("space.settings.edit.policies_title"),
                     description: t("space.settings.edit.policies_link_hint"),
                     summary: settings_policy_summary(@space) %>
        <% end %>

        <%= render "shared/settings_link_card",
                   path: settings_whatsapp_path,
                   title: t("settings.sidebar.whatsapp"),
                   description: t("settings.sidebar.descriptions.whatsapp"),
                   summary: settings_whatsapp_summary(@space),
                   badge: (@space.whatsapp_phone_number&.active? ? t("settings.shared.whatsapp.connected") : nil) %>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", hint: t("space.settings.edit.submit") do %>
        <%= form.submit t("space.settings.edit.submit"),
                        class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                        data: { turbo_submits_with: t("shared.submitting") } %>
    <% end %>
  <% end %>
</div>
