<li id="<%= dom_id(appointment) %>" class="card p-3 text-sm<%= " data-controller=\"action-feedback\"" if local_assigns[:animated] %>">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-slate-900">
        <%= format_appointment_time(appointment.scheduled_at, space: appointment.space, format: :long) || "—" %>
      </p>
      <p class="mt-0.5 text-xs text-slate-500">
        <%= t("space.customers.show.status_prefix") %> <%= t("activerecord.attributes.appointment.status.#{appointment.status}") %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <% if current_user.can?(:manage_appointments) %>
        <% if appointment.pending? %>
          <%= button_to t("space.appointments.index.confirm"), confirm_appointment_path(appointment),
                method: :patch,
                params: { source: "customer_show" },
                data: { turbo_submits_with: t("shared.submitting") },
                class: button_classes(:table_success) %>
        <% end %>
        <% if appointment.pending? || appointment.confirmed? %>
          <%= button_to t("space.appointments.index.cancel"), cancel_appointment_path(appointment),
                method: :patch,
                params: { source: "customer_show" },
                data: { turbo_confirm: t("space.appointments.index.cancel_confirm"), turbo_submits_with: t("shared.submitting") },
                class: button_classes(:table_cancel) %>
        <% end %>
      <% end %>
      <%= link_to t("space.appointments.index.view"), appointment_path(appointment), class: button_classes(:table_link) %>
    </div>
  </div>
</li>
