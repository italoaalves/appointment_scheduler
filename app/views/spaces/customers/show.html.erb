<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.customers"), path: customers_path },
  { label: @customer.name.presence || "—" }
] } %>
<div class="space-y-6">
  <header class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        <%= t("space.customers.show.title") %>
      </h1>
      <p class="mt-1 text-xs text-slate-600">
        <%= t("space.customers.show.subtitle") %>
      </p>
    </div>
  </header>

  <div class="panel-card-compact">
    <dl class="detail-list">
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.customers.show.name") %></dt>
        <dd class="detail-list__value"><%= @customer.name %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.customers.show.phone") %></dt>
        <dd class="detail-list__value"><%= @customer.phone.presence || "—" %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.customers.show.email") %></dt>
        <dd class="detail-list__value"><%= @customer.email.presence || "—" %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.customers.show.address") %></dt>
        <dd class="detail-list__value"><%= @customer.address.presence || "—" %></dd>
      </div>
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.customers.show.whatsapp_consent") %></dt>
        <dd class="detail-list__value text-right">
          <% if @customer.whatsapp_opted_in? %>
            <%= t("space.customers.show.whatsapp_consent_granted", date: l(@customer.whatsapp_opted_in_at, format: :short)) %>
          <% elsif @customer.whatsapp_opted_out_at.present? %>
            <%= t("space.customers.show.whatsapp_consent_revoked", date: l(@customer.whatsapp_opted_out_at, format: :short)) %>
          <% else %>
            <%= t("space.customers.show.whatsapp_consent_missing") %>
          <% end %>
        </dd>
      </div>
    </dl>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= link_to t("space.customers.show.edit_customer"),
                edit_customer_path(@customer),
                class: button_classes(:primary) %>
    <%= button_to t("space.customers.show.delete_customer"),
                  customer_path(@customer),
                  method: :delete,
                  data: { turbo_confirm: t("space.customers.show.delete_customer_confirm"), turbo_submits_with: t("shared.deleting") },
                  class: button_classes(:danger) %>
  </div>

  <section class="space-y-3">
    <h2 class="text-sm font-semibold text-slate-900">
      <%= t("space.customers.show.appointments_title") %>
    </h2>

    <% if @appointments.any? %>
      <ul class="space-y-2">
        <%= render partial: "customer_appointment", collection: @appointments, as: :appointment %>
      </ul>
      <%= paginate @appointments %>
    <% else %>
      <p class="text-sm text-slate-600">
        <%= t("space.customers.show.no_appointments") %>
      </p>
    <% end %>
  </section>
</div>
