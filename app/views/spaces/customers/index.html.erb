<% content_for(:wide_layout) { "" } %>
<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.customers") }
] } %>

<% if turbo_frame_request? %>
  <turbo-frame id="<%= request.headers["Turbo-Frame"] %>">
    <%= render "feed_page", grouped_customers: @grouped_customers, customers: @customers %>
  </turbo-frame>
<% else %>
  <div class="space-y-6">
    <% page_actions = capture do %>
      <% if Billing::PlanEnforcer.can?(current_tenant, :create_customer) %>
        <%= link_to t("space.customers.index.new_button"), new_customer_path, class: button_classes(:primary) %>
      <% else %>
        <span class="text-sm text-slate-500"><%= t("billing.limits.customers_exceeded") %></span>
      <% end %>
    <% end %>
    <%= render "application/shared/page_header", title: t("space.customers.index.title"), actions: page_actions %>

    <%= render "application/shared/search_bar",
               url: customers_path,
               query: params[:query],
               placeholder: t("space.customers.index.filters.search_placeholder"),
               turbo_frame: "customers-feed",
               clear_path: customers_path,
               clear_label: t("space.customers.index.filters.clear") %>

    <turbo-frame id="customers-feed"
                 data-controller="infinite-scroll"
                 data-infinite-scroll-card-selector-value=".customer-card">
      <%= render "feed_page", grouped_customers: @grouped_customers, customers: @customers %>
    </turbo-frame>
  </div>
<% end %>
