<% content_for(:wide_layout) { "" } %>
<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.customers") }
] } %>

<% if turbo_frame_request? %>
  <turbo-frame id="<%= request.headers["Turbo-Frame"] %>">
    <%= render "feed_page", grouped_customers: @grouped_customers, customers: @customers %>
  </turbo-frame>
<% else %>
  <div class="space-y-6">
    <% page_actions = capture do %>
      <% if Billing::PlanEnforcer.can?(current_tenant, :create_customer) %>
        <%= link_to t("space.customers.index.new_button"), new_customer_path, class: button_classes(:primary) %>
      <% else %>
        <span class="text-sm text-slate-500"><%= t("billing.limits.customers_exceeded") %></span>
      <% end %>
    <% end %>
    <%= render "application/shared/page_header", title: t("space.customers.index.title"), actions: page_actions %>

    <%= form_with url: customers_path,
                  method: :get,
                  local: true,
                  data: { controller: "auto-submit", turbo_frame: "customers-feed" },
                  class: "card-glass flex items-center gap-2 p-3" do %>
      <div class="flex-1">
        <%= text_field_tag :query, params[:query],
                           placeholder: t("space.customers.index.filters.search_placeholder"),
                           class: "w-full rounded-md border-slate-300 text-base focus:border-slate-500 focus:ring-slate-500 py-2.5",
                           data: { auto_submit_target: "input", action: "input->auto-submit#search" } %>
      </div>
      <%= link_to customers_path,
            class: "flex-shrink-0 p-2 rounded-md text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors",
            aria: { label: t("space.customers.index.filters.clear") },
            data: { turbo_frame: "customers-feed" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>
    <% end %>

    <turbo-frame id="customers-feed"
                 data-controller="infinite-scroll"
                 data-infinite-scroll-card-selector-value=".customer-card">
      <%= render "feed_page", grouped_customers: @grouped_customers, customers: @customers %>
    </turbo-frame>
  </div>
<% end %>
