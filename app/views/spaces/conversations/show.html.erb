<% content_for(:inbox_layout) { true } %>

<div class="flex h-full min-h-0 min-w-0 w-full max-w-full max-h-[calc(100dvh-var(--spacing-inbox-mobile-chrome))] flex-col overflow-x-clip overflow-y-hidden pb-[calc(6.5rem+env(safe-area-inset-bottom))] sm:pb-0 sm:max-h-[calc(100dvh-var(--spacing-inbox-desktop-chrome))]"
     data-controller="inbox">

  <%= render "spaces/conversations/detail_frame",
             conversation: @conversation,
             standalone: true,
             channel: @channel,
             can_write_inbox: @can_write_inbox %>

</div>
