<div class="grid grid-cols-2 gap-3">
  <%# Channel %>
  <div>
    <%= f.label :channel, t("spaces.conversations.index.filters.channel"), class: "form-label-sm mb-1" %>
    <%= f.select :channel, options_for_select([
      [t("spaces.conversations.index.filters.all_channels"), ""],
      [t("spaces.conversations.index.filters.channel_whatsapp"), "whatsapp"],
      [t("spaces.conversations.index.filters.channel_email"), "email"],
      [t("spaces.conversations.index.filters.channel_sms"), "sms"],
      [t("spaces.conversations.index.filters.channel_instagram"), "instagram"],
      [t("spaces.conversations.index.filters.channel_messenger"), "messenger"]
    ], params[:channel]), {}, { class: "form-input-sm" } %>
  </div>

  <%# Priority %>
  <div>
    <%= f.label :priority, t("spaces.conversations.index.filters.priority"), class: "form-label-sm mb-1" %>
    <%= f.select :priority, options_for_select([
      [t("spaces.conversations.index.filters.all_priorities"), ""],
      [t("spaces.conversations.index.priority.low"), "low"],
      [t("spaces.conversations.index.priority.normal"), "normal"],
      [t("spaces.conversations.index.priority.high"), "high"],
      [t("spaces.conversations.index.priority.urgent"), "urgent"]
    ], params[:priority]), {}, { class: "form-input-sm" } %>
  </div>

  <%# Date range %>
  <div>
    <%= f.label :since, t("spaces.conversations.index.filters.since"), class: "form-label-sm mb-1" %>
    <%= f.date_field :since, value: params[:since], class: "form-input-sm" %>
  </div>

  <div>
    <%= f.label :until, t("spaces.conversations.index.filters.until"), class: "form-label-sm mb-1" %>
    <%= f.date_field :until, value: params[:until], class: "form-input-sm" %>
  </div>

  <%# Assigned to %>
  <div class="col-span-2">
    <%= f.label :assigned_to, t("spaces.conversations.index.filters.assigned_to"), class: "form-label-sm mb-1" %>
    <% assignee_options = (@space_users || current_tenant.users.order(:name)).map { |user| [user.name.presence || user.email, user.id] } %>
    <%= f.select :assigned_to, options_for_select(
      [[t("spaces.conversations.index.filters.include_unassigned"), "none"]] + assignee_options,
      params[:assigned_to]
    ), { include_blank: t("spaces.conversations.index.filters.assigned_to") }, { class: "form-input-sm" } %>
  </div>

  <div class="col-span-2 flex flex-wrap gap-3 pt-1">
    <label class="inline-flex items-center gap-2 text-xs text-slate-500">
      <%= f.check_box :unread, { checked: params[:unread] == "true", class: "rounded border-slate-300 text-electric focus:ring-electric/30" }, "true", "false" %>
      <span><%= t("spaces.conversations.index.filters.unread") %></span>
    </label>

    <label class="inline-flex items-center gap-2 text-xs text-slate-500">
      <%= f.check_box :sla_breached, { checked: params[:sla_breached] == "true", class: "rounded border-slate-300 text-electric focus:ring-electric/30" }, "true", "false" %>
      <span><%= t("spaces.conversations.index.filters.only_breached") %></span>
    </label>
  </div>
</div>
