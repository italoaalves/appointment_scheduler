<%= link_to spaces_inbox_path(conversation), data: { turbo_frame: "conversation_detail" }, class: "block p-4 hover:bg-slate-50 transition" do %>
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 mt-0.5">
      <%= render "spaces/conversations/channel_badge", channel: conversation.channel %>
    </div>

    <div class="flex-1 min-w-0">
      <%# Contact name and unread indicator %>
      <div class="flex items-center gap-1.5 mb-1">
        <span class="font-medium text-slate-900 truncate">
          <%= conversation.contact_name.presence || conversation.customer&.name || conversation.contact_identifier %>
        </span>
        <% if conversation.unread? %>
          <span class="inline-block h-2 w-2 rounded-full bg-electric" aria-label="<%= t("spaces.conversations.index.unread") %>"></span>
        <% end %>
      </div>

      <p class="text-sm text-slate-500 truncate mb-1">
        <%= conversation.last_message_body.presence || "—" %>
      </p>

      <%# Time ago and priority %>
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <span>
          <%= time_ago_in_words(conversation.last_message_at) %>
        </span>
        <%# Priority badge %>
        <% case conversation.priority %>
        <% when "low" %>
          <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-800"><%= t("spaces.conversations.index.priority.low") %></span>
        <% when "normal" %>
          <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-700"><%= t("spaces.conversations.index.priority.normal") %></span>
        <% when "high" %>
          <span class="px-2 py-0.5 rounded-full bg-orange-100 text-orange-800"><%= t("spaces.conversations.index.priority.high") %></span>
        <% when "urgent" %>
          <span class="px-2 py-0.5 rounded-full bg-red-100 text-red-800"><%= t("spaces.conversations.index.priority.urgent") %></span>
        <% end %>

        <% if conversation.sla_breached? %>
          <span class="px-1.5 py-0.5 rounded-full bg-red-100 text-red-600 text-[10px] font-semibold"><%= t("spaces.conversations.index.sla_breached") %></span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>