<%= link_to spaces_conversations_path(conversation), data: { turbo_frame: "conversation_detail" }, class: "block p-4 hover:bg-slate-50 transition" do %>
  <div class="flex items-start gap-3">
    <%# Channel icon %>
    <div class="flex-shrink-0 mt-0.5">
      <% case conversation.channel %>
      <% when "whatsapp" %>
        <%= image_tag "channels/whatsapp.png", alt: "WhatsApp", class: "w-6 h-6" %>
      <% when "email" %>
        <%= image_tag "channels/email.png", alt: "Email", class: "w-6 h-6" %>
      <% when "sms" %>
        <%= image_tag "channels/sms.png", alt: "SMS", class: "w-6 h-6" %>
      <% when "instagram" %>
        <%= image_tag "channels/instagram.png", alt: "Instagram", class: "w-6 h-6" %>
      <% when "messenger" %>
        <%= image_tag "channels/messenger.png", alt: "Messenger", class: "w-6 h-6" %>
      <% end %>
    </div>

    <div class="flex-1 min-w-0">
      <%# Contact name and unread indicator %>
      <div class="flex items-center gap-1.5 mb-1">
        <span class="font-medium text-slate-900 truncate">
          <%= conversation.customer&.name || conversation.contact_identifier %>
        </span>
        <% if conversation.unread? %>
          <span class="inline-block h-2 w-2 rounded-full bg-indigo-500" aria-label="<%= t("spaces.conversations.index.unread") %>"></span>
        <% end %>
      </div>

      <%# Last message preview %>
      <p class="text-sm text-slate-500 truncate mb-1">
        <% last_message = conversation.conversation_messages.last %>
        <%= last_message&.body&.truncate(80) || "—" %>
      </p>

      <%# Time ago and priority %>
      <div class="flex items-center gap-2 text-xs text-slate-400">
        <span>
          <%= time_ago_in_words(conversation.last_message_at) %>
        </span>
        <%# Priority badge %>
        <% case conversation.priority %>
        <% when "low" %>
          <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-800"><%= t("spaces.conversations.index.priority.low") %></span>
        <% when "normal" %>
          <span class="px-2 py-0.5 rounded-full bg-gray-100 text-gray-800"><%= t("spaces.conversations.index.priority.normal") %></span>
        <% when "high" %>
          <span class="px-2 py-0.5 rounded-full bg-orange-100 text-orange-800"><%= t("spaces.conversations.index.priority.high") %></span>
        <% when "urgent" %>
          <span class="px-2 py-0.5 rounded-full bg-red-100 text-red-800"><%= t("spaces.conversations.index.priority.urgent") %></span>
        <% end %>

        <%# SLA breach indicator %>
        <% if conversation.sla_breached? %>
          <span class="flex items-center gap-0.5 text-red-500">
            <%= image_tag "clock-red.svg", alt: "SLA breached", class: "w-3 h-3" %>
          </span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>