<% content_for(:inbox_layout) { true } %>

<div class="flex h-full min-h-0 min-w-0 w-full max-w-full max-h-[calc(100dvh-var(--spacing-inbox-mobile-chrome))] flex-col overflow-x-hidden sm:max-h-[calc(100dvh-var(--spacing-inbox-desktop-chrome))]"
     data-controller="inbox"
     data-inbox-tab-value="<%= params[:tab].presence || 'needs_reply' %>">

  <%# ── Segment bar ─────────────────────────────────────────────── %>
  <div class="z-20 w-full max-w-full shrink-0 overflow-x-hidden glass-frosty border-b border-slate-200/40 px-4 py-3">
    <div class="flex min-w-0 w-full max-w-full items-center gap-2 overflow-x-hidden">

      <%# Tab pills %>
      <% current_tab = params[:tab].presence || "needs_reply" %>
      <div class="min-w-0 flex-1 max-w-full overflow-x-auto overflow-y-hidden">
        <div class="inline-flex min-w-max max-w-none gap-1 rounded-full bg-slate-100/80 p-1">
        <% [["needs_reply", t("spaces.conversations.index.tab_needs_reply")],
            ["open",        t("spaces.conversations.index.tab_open")],
            ["all",         t("spaces.conversations.index.tab_all")]].each do |tab, label| %>
          <%= link_to spaces_inbox_index_path(tab: tab, q: params[:q]),
                      class: "px-3 py-1.5 text-xs font-medium rounded-full transition-all whitespace-nowrap #{current_tab == tab ? 'bg-white text-deep shadow-sm' : 'text-slate-500 hover:text-deep'}",
                      data: {
                        turbo_frame: "conversation_list",
                        turbo_action: "replace",
                        action: "click->inbox#tabSelected",
                        inbox_target: "tab",
                        tab_name: tab
                      } do %>
            <%= label %>
          <% end %>
        <% end %>
        </div>
      </div>

      <%# Search + filter icon buttons %>
      <div class="ml-auto flex shrink-0 items-center gap-1">
        <button type="button"
                class="p-2 rounded-xl text-slate-400 hover:text-deep hover:bg-slate-100/60 transition-colors"
                data-action="click->inbox#toggleSearch"
                aria-label="<%= t('spaces.conversations.index.search') %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>
        <button type="button"
                class="p-2 rounded-xl text-slate-400 hover:text-deep hover:bg-slate-100/60 transition-colors"
                data-action="click->inbox#toggleFilters"
                aria-label="<%= t('spaces.conversations.index.filters_toggle') %>">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z" />
          </svg>
        </button>
      </div>
    </div>

    <%# Search + advanced filters form (hidden by default) %>
    <%= form_with url: spaces_inbox_index_path, method: :get,
                  data: { turbo_frame: "conversation_list", turbo_action: "replace", inbox_target: "filterForm" } do |f| %>
      <%= f.hidden_field :tab, value: current_tab %>

      <%# Search input — toggled by search button %>
      <div class="hidden mt-3" data-inbox-target="searchBar">
        <%= f.text_field :q,
                         value: params[:q],
                         placeholder: t("spaces.conversations.index.search_placeholder"),
                         class: "form-input-sm",
                         autocomplete: "off",
                         data: { inbox_target: "searchInput", action: "input->inbox#debouncedSearch" } %>
      </div>

      <%# Advanced filters — toggled by filter button %>
      <div class="hidden mt-3" data-inbox-target="filterDrawer">
        <%= render "spaces/conversations/filters", f: f %>
        <div class="mt-3 flex justify-end">
          <%= f.submit t("spaces.conversations.index.apply_filters"),
                       class: "btn-primary btn-sm btn-xs cursor-pointer" %>
        </div>
      </div>
    <% end %>
  </div>

  <%# ── Main content: list + detail ───────────────────────────── %>
  <div class="flex flex-1 min-h-0 min-w-0 w-full max-w-full overflow-x-hidden">

    <%# List panel — full width on mobile, fixed 320px on desktop %>
    <div class="w-full max-w-full min-w-0 basis-full sm:w-80 sm:max-w-80 sm:basis-80 sm:shrink-0 overflow-x-hidden overflow-y-auto border-r border-slate-200/60 pb-[calc(6.5rem+env(safe-area-inset-bottom))] sm:pb-4"
         data-inbox-target="listPanel">
      <%= turbo_frame_tag "conversation_list", class: "block w-full max-w-full min-w-0 overflow-x-hidden" do %>
        <% if @conversations.any? %>
          <div class="w-full max-w-full min-w-0 divide-y divide-slate-100 overflow-x-hidden">
            <% @conversations.each do |conversation| %>
              <%= render "spaces/conversations/conversation",
                         conversation: conversation,
                         selected: @conversation&.id == conversation.id %>
            <% end %>
          </div>
          <% if @conversations.respond_to?(:total_pages) && @conversations.total_pages > 1 %>
            <div class="p-4 flex justify-center">
              <%= paginate @conversations %>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center py-16 px-6 text-center">
            <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
              </svg>
            </div>
            <p class="text-sm font-medium text-slate-600"><%= t("spaces.conversations.index.empty") %></p>
            <p class="text-xs text-slate-400 mt-1"><%= t("spaces.conversations.index.empty_subtitle") %></p>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Detail panel — hidden on mobile, visible on desktop %>
    <div class="hidden w-full max-w-full min-w-0 sm:flex flex-col flex-1 min-h-0 overflow-hidden"
         data-inbox-target="detailPanel">
      <% if @conversation.present? %>
        <%= render "spaces/conversations/detail_frame",
                   conversation: @conversation,
                   standalone: false,
                   channel: @channel,
                   can_write_inbox: @can_write_inbox %>
      <% else %>
        <%= turbo_frame_tag "conversation_detail", class: "flex flex-col flex-1 min-h-0 h-full overflow-hidden" do %>
          <div class="flex flex-col items-center justify-center h-full text-center py-16 px-6">
            <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <p class="text-sm font-medium text-slate-600"><%= t("spaces.conversations.index.detail_placeholder") %></p>
            <p class="text-xs text-slate-400 mt-1"><%= t("spaces.conversations.index.detail_placeholder_subtitle") %></p>
          </div>
        <% end %>
      <% end %>
    </div>

  </div>
</div>
