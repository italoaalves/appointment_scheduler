<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.billing") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>
<div class="space-y-6">
  <%= render "application/shared/settings_intro",
             eyebrow: t("settings.sidebar.billing_section"),
             title: t("billing.show.title"),
             subtitle: t("billing.show.subtitle"),
             statuses: (@subscription ? [
               settings_intro_status(t("billing.show.subscription_status"), @subscription.status.humanize, tone: (@subscription.active? || @subscription.trialing? ? :success : :warning)),
               (@current_plan ? settings_intro_status(t("billing.show.current_plan"), @current_plan.name, tone: :accent) : nil)
             ] : []) %>

  <% if @subscription.nil? %>
    <%= render "application/shared/settings_panel",
               title: t("billing.show.current_plan"),
               description: t("billing.show.no_subscription") do %>
      <p class="text-sm text-slate-600"><%= t("billing.show.no_subscription") %></p>
    <% end %>
  <% else %>
    <%= render "application/shared/settings_panel",
               title: t("billing.show.current_plan"),
               description: t("billing.show.subscription_overview") do %>
      <div class="space-y-5">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
          <div>
            <h2 class="text-xl font-bold text-deep"><%= @current_plan&.name %></h2>
            <% if @subscription.pending_billing_plan.present? %>
              <p class="mt-2 text-sm text-amber-700">
                <%= t("billing.show.pending_downgrade",
                      plan: @subscription.pending_billing_plan.name,
                      date: l(@subscription.current_period_end.to_date, format: :long)) %>
              </p>
            <% end %>
          </div>

          <%= render "application/shared/status_badge",
                     status: @subscription.status,
                     label: @subscription.status.humanize %>
        </div>

        <% if (@subscription.trialing? && @subscription.trial_ends_at) ||
              (@subscription.current_period_start && @subscription.current_period_end) ||
              @subscription.pending_payment? ||
              (@subscription.canceled? && @subscription.current_period_end&.future?) %>
          <div class="grid gap-4 xl:grid-cols-2 2xl:grid-cols-3">
            <% if @subscription.trialing? && @subscription.trial_ends_at %>
              <div class="settings-info-tile">
                <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("billing.show.subscription_status") %></p>
                <p class="mt-1 text-sm font-semibold text-deep"><%= t("billing.show.trial_ends", date: l(@subscription.trial_ends_at.to_date, format: :long)) %></p>
              </div>
            <% elsif @subscription.current_period_start && @subscription.current_period_end %>
              <div class="settings-info-tile">
                <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("billing.show.payment_date") %></p>
                <p class="mt-1 text-sm font-semibold text-deep">
                  <%= t("billing.show.billing_period",
                        from: l(@subscription.current_period_start.to_date, format: :long),
                        to: l(@subscription.current_period_end.to_date, format: :long)) %>
                </p>
              </div>
            <% end %>

            <% if @subscription.pending_payment? %>
              <div class="rounded-card border border-amber-200 bg-amber-50 p-4">
                <p class="text-xs font-medium uppercase tracking-wide text-amber-700"><%= t("billing.show.subscription_status") %></p>
                <p class="mt-1 text-sm font-semibold text-amber-900"><%= t("billing.show.awaiting_first_payment") %></p>
              </div>
            <% end %>

            <% if @subscription.canceled? && @subscription.current_period_end&.future? %>
              <div class="rounded-card border border-amber-200 bg-amber-50 p-4">
                <p class="text-xs font-medium uppercase tracking-wide text-amber-700"><%= t("billing.show.subscription_status") %></p>
                <p class="mt-1 text-sm font-semibold text-amber-900">
                  <%= t("billing.show.cancel_pending",
                        date: l(@subscription.current_period_end.to_date, format: :long)) %>
                </p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @subscription.canceled? && @subscription.current_period_end&.future? %>
          <div class="flex flex-wrap gap-3">
            <%= button_to t("billing.show.reactivate"), resubscribe_settings_billing_path,
                          method: :patch,
                          class: button_classes(:primary) %>
          </div>
        <% elsif @subscription.expired? || @subscription.canceled? %>
          <div class="flex flex-wrap gap-3">
            <%= button_to t("billing.show.resubscribe"), resubscribe_settings_billing_path,
                          method: :patch,
                          class: button_classes(:primary) %>
          </div>
        <% else %>
          <div class="flex flex-wrap gap-3">
            <%= link_to t("billing.show.change_plan"), edit_settings_billing_path,
                        class: button_classes(:secondary) %>
            <% cancel_confirm = if @subscription.trialing?
                                 t("billing.show.cancel_confirm_trial")
                               else
                                 t("billing.show.cancel_confirm_deferred",
                                   date: l(@subscription.current_period_end.to_date, format: :long))
                               end %>
            <%= button_to t("billing.show.cancel_subscription"), cancel_settings_billing_path,
                          method: :patch,
                          data: { turbo_confirm: cancel_confirm },
                          class: button_classes(:destructive) %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @current_plan %>
      <%= render "application/shared/settings_panel",
                 title: t("billing.show.plan_limits"),
                 description: t("billing.show.plan_limits_hint") do %>
        <dl class="grid gap-4 xl:grid-cols-3">
          <div class="settings-info-tile">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("billing.show.team_members") %></dt>
            <dd class="mt-1 text-xl font-bold text-deep">
              <%= current_tenant.space_memberships.count %> /
              <%= @current_plan.max_team_members.nil? ? "∞" : @current_plan.max_team_members %>
            </dd>
          </div>
          <div class="settings-info-tile">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("billing.show.customers") %></dt>
            <dd class="mt-1 text-xl font-bold text-deep">
              <%= current_tenant.customers.count %> /
              <%= @current_plan.max_customers.nil? ? "∞" : @current_plan.max_customers %>
            </dd>
          </div>
          <div class="settings-info-tile">
            <dt class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("billing.show.scheduling_links") %></dt>
            <dd class="mt-1 text-xl font-bold text-deep">
              <%= current_tenant.scheduling_links.count %> /
              <%= @current_plan.max_scheduling_links.nil? ? "∞" : @current_plan.max_scheduling_links %>
            </dd>
          </div>
        </dl>
      <% end %>
    <% end %>

    <% if @payments.any? %>
      <%= render "application/shared/settings_panel",
                 title: t("billing.show.payment_history"),
                 description: t("billing.show.payment_history_hint") do %>
        <div class="space-y-3">
          <% @payments.each do |payment| %>
            <div class="settings-info-tile flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
              <div class="space-y-1">
                <p class="text-sm font-semibold text-deep">
                  <%= payment.paid_at ? l(payment.paid_at.to_date, format: :long) : "—" %>
                </p>
                <p class="text-sm text-slate-600">
                  <%= number_to_currency(payment.amount_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
                </p>
              </div>

              <%= render "application/shared/status_badge",
                         status: payment.status,
                         label: payment.status.humanize %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
