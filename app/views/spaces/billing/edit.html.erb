<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.billing"), path: settings_billing_path },
  { label: t("breadcrumbs.change_plan") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<% plans_json = @plans.to_h { |p| [p.id.to_s, { name: p.name, price: p.price_cents, slug: p.slug }] } %>

<div class="space-y-6"
     data-controller="plan-change"
     data-plan-change-plans-value="<%= plans_json.to_json %>"
     data-plan-change-current-price-value="<%= @subscription&.billing_plan&.price_cents || 0 %>"
     data-plan-change-payment-method-value="<%= @subscription&.payment_method %>">

  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.billing_section"),
             title: t("billing.edit.title"),
             subtitle: t("billing.edit.subtitle"),
             statuses: [
               (@subscription&.billing_plan ? settings_intro_status(t("billing.show.current_plan"), @subscription.billing_plan.name, tone: :accent) : nil),
               (@subscription&.payment_method ? settings_intro_status(t("billing.checkout.payment_method"), t("billing.payment_methods.#{@subscription.payment_method}"), tone: :neutral) : nil)
             ] %>

  <form data-plan-change-target="form"
        id="plan-change-form"
        action="<%= settings_billing_path %>" method="post" class="hidden">
    <input type="hidden" name="_method" value="patch">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <input type="hidden" name="billing_plan_id" data-plan-change-target="planIdInput">
    <input type="hidden" name="payment_method" data-plan-change-target="paymentMethodInput"
           value="<%= @subscription&.payment_method %>">
  </form>

  <div data-plan-change-target="grid">
    <%= render "shared/settings_panel",
               title: t("billing.edit.plan_grid_title"),
               description: t("billing.edit.plan_grid_hint") do %>
      <div class="grid gap-4 xl:grid-cols-2 2xl:grid-cols-3">
        <% @plans.each do |plan| %>
          <% is_current = @subscription&.billing_plan_id == plan.id %>
          <% border_classes = if is_current
                                "border-electric/30 ring-1 ring-electric/10"
                              elsif plan.highlighted?
                                "border-deep/20"
                              else
                                "border-slate-200"
                              end %>

          <%= render "shared/card",
                     extra_class: "h-full rounded-card border-2 p-5 #{border_classes}" do %>
            <div class="flex h-full flex-col">
              <div class="mb-3 flex min-h-[1.5rem] flex-wrap gap-1.5">
                <% if plan.highlighted? %>
                  <span class="badge badge-cerulean"><%= t("billing.edit.recommended") %></span>
                <% end %>
                <% if is_current %>
                  <span class="badge badge-emerald"><%= t("billing.edit.current") %></span>
                <% end %>
              </div>

              <h2 class="text-lg font-semibold text-deep"><%= plan.name %></h2>
              <p class="mt-1 text-2xl font-bold text-deep">
                <%= plan.price_cents == 0 ? t("billing.edit.free") : number_to_currency(plan.price_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
                <span class="text-sm font-normal text-slate-500">/ <%= t("billing.edit.month") %></span>
              </p>

              <ul class="mt-4 flex-1 space-y-2 text-sm text-slate-700">
                <li>✓ <%= t("billing.edit.team_members", count: plan.max_team_members.nil? ? "∞" : plan.max_team_members) %></li>
                <li>✓ <%= t("billing.edit.customers_limit", count: plan.max_customers.nil? ? "∞" : plan.max_customers) %></li>
                <li>✓ <%= t("billing.edit.links_limit", count: plan.max_scheduling_links.nil? ? "∞" : plan.max_scheduling_links) %></li>
                <% if plan.feature?(:personalized_booking_page) %>
                  <li>✓ <%= t("billing.edit.personalized_page") %></li>
                <% end %>
                <% if plan.feature?(:custom_appointment_policies) %>
                  <li>✓ <%= t("billing.edit.custom_policies") %></li>
                <% end %>
                <% if plan.feature?(:priority_support) %>
                  <li>✓ <%= t("billing.edit.priority_support") %></li>
                <% end %>
                <% if plan.whatsapp_monthly_quota.nil? %>
                  <li>✓ <%= t("billing.edit.whatsapp_unlimited") %></li>
                <% elsif plan.whatsapp_monthly_quota > 0 %>
                  <li>✓ <%= t("billing.edit.whatsapp_quota", count: plan.whatsapp_monthly_quota) %></li>
                <% end %>
              </ul>

              <div class="mt-5">
                <% if is_current %>
                  <button type="button" disabled
                          class="w-full cursor-not-allowed rounded-card border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-400">
                    <%= t("billing.edit.current") %>
                  </button>
                <% else %>
                  <button type="button"
                          data-action="plan-change#select"
                          data-plan-change-id-param="<%= plan.id %>"
                          class="w-full <%= button_classes(:primary) %>">
                    <%= t("billing.edit.select_plan") %>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div data-plan-change-target="confirmation" hidden class="space-y-4">
    <%= render "shared/settings_panel",
               title: t("billing.edit.confirm_change"),
               description: t("billing.edit.confirm_change_hint") do %>
      <div class="grid gap-4 xl:grid-cols-3 xl:items-center">
        <div class="settings-info-tile text-center">
          <p class="meta-label"><%= t("billing.edit.current_plan_label") %></p>
          <p class="mt-1 text-lg font-bold text-deep" data-plan-change-target="currentName">
            <%= @subscription&.billing_plan&.name %>
          </p>
          <p class="mt-1 text-sm text-slate-600" data-plan-change-target="currentPrice">
            <%= number_to_currency((@subscription&.billing_plan&.price_cents || 0) / 100.0, unit: "R$", separator: ",", delimiter: ".") %>/<%= t("billing.edit.month") %>
          </p>
        </div>

        <div class="flex items-center justify-center text-2xl text-slate-300">→</div>

        <div class="settings-info-tile text-center">
          <p class="meta-label"><%= t("billing.edit.new_plan_label") %></p>
          <p class="mt-1 text-lg font-bold text-deep" data-plan-change-target="newName"></p>
          <p class="mt-1 text-sm text-slate-600" data-plan-change-target="newPrice"></p>
        </div>
      </div>
    <% end %>

    <div data-plan-change-target="upgradeNotice" hidden
         class="rounded-card border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-800">
      <%= t("billing.edit.upgrade_notice") %>
    </div>

    <div data-plan-change-target="downgradeNotice" hidden
         class="rounded-card border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      <%= t("billing.edit.downgrade_notice") %>
      <span class="font-medium">
        <%= @subscription&.current_period_end ? l(@subscription.current_period_end.to_date, format: :long) : "" %>
      </span>
    </div>

    <div data-plan-change-target="manualPaymentWarning" hidden
         class="rounded-card border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      <%= t("billing.edit.manual_payment_warning") %>
    </div>

    <%= render "shared/settings_panel",
               title: t("billing.edit.change_payment_method"),
               description: t("billing.edit.payment_method_hint") do %>
      <div class="grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
        <% Billing::Subscription.payment_methods.each_key do |method| %>
          <label class="settings-choice-card">
            <input type="radio" name="pm_display" value="<%= method %>"
                   data-action="plan-change#updatePaymentMethod"
                   <%= method.to_s == @subscription&.payment_method ? "checked" : "" %>
                   class="h-4 w-4 accent-electric">
            <span><%= t("billing.payment_methods.#{method}") %></span>
          </label>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/settings_action_bar", hint: t("billing.edit.confirmation_hint") do %>
      <button type="button" data-action="plan-change#back"
              class="<%= "#{button_classes(:secondary)} w-full justify-center lg:w-auto" %>">
        <%= t("billing.edit.back") %>
      </button>
      <button type="button" data-action="plan-change#confirm"
              class="<%= "#{button_classes(:primary)} w-full justify-center lg:w-auto" %>">
        <%= t("billing.edit.confirm_button") %>
      </button>
    <% end %>
  </div>
</div>
