<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("breadcrumbs.billing"), path: settings_billing_path },
  { label: t("breadcrumbs.checkout") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<div class="space-y-6"
     data-controller="checkout-wizard"
     data-checkout-wizard-prices-value="<%= @plans.to_h { |p| [p.slug, p.price_cents] }.to_json %>">

  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.billing_section"),
             title: t("billing.checkout.title"),
             subtitle: t("billing.checkout.subtitle") %>

  <%= form_with url: subscribe_settings_billing_path, method: :post, class: "space-y-6" do |f| %>
    <input type="hidden" name="plan_id" data-checkout-wizard-target="planInput" />

    <div data-checkout-wizard-target="step1">
      <%= render "shared/settings_panel",
                 title: t("billing.checkout.plan_selection_title"),
                 description: t("billing.checkout.plan_selection_hint") do %>
        <div class="grid gap-4 xl:grid-cols-2 2xl:grid-cols-3">
          <% @plans.each do |plan| %>
            <% is_current = @current_plan&.id == plan.id %>
            <% border_classes = plan.highlighted? ? "border-deep/20" : "border-slate-200" %>

            <%= render "shared/card",
                       extra_class: "h-full rounded-card border-2 p-5 #{border_classes}" do %>
              <div class="flex h-full flex-col">
                <div class="mb-3 flex min-h-[1.5rem] flex-wrap gap-1.5">
                  <% if plan.highlighted? %>
                    <span class="badge badge-cerulean"><%= t("billing.checkout.recommended") %></span>
                  <% end %>
                  <% if is_current %>
                    <span class="badge badge-emerald"><%= t("billing.edit.current") %></span>
                  <% end %>
                </div>

                <h2 class="text-lg font-bold text-deep"><%= plan.name %></h2>
                <p class="mt-1 text-2xl font-bold text-deep">
                  <%= number_to_currency(plan.price_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
                  <span class="text-sm font-normal text-slate-500">/ <%= t("billing.edit.month") %></span>
                </p>

                <ul class="mt-4 flex-1 space-y-2 border-t border-slate-100 pt-4 text-sm">
                  <% BillingHelper::PLAN_COMPARISON_ROWS.each do |row| %>
                    <li class="flex items-center justify-between gap-3">
                      <span class="text-slate-500"><%= row[:label] %></span>
                      <span class="font-medium text-deep">
                        <% case row[:format]
                           when :limit %><%= format_plan_limit(plan.public_send(row[:key])) %><%
                           when :quota %><%= format_whatsapp_quota(plan.public_send(row[:key])) %><%
                           when :feature %><%= format_plan_feature(plan, row[:key]) %><%
                           end %>
                      </span>
                    </li>
                  <% end %>
                </ul>

                <div class="mt-5">
                  <% if is_current %>
                    <button type="button" disabled
                            class="w-full cursor-not-allowed rounded-card border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-medium text-slate-400">
                      <%= t("billing.edit.current") %>
                    </button>
                  <% else %>
                    <button type="button"
                            data-action="checkout-wizard#pick"
                            data-checkout-wizard-slug-param="<%= plan.slug %>"
                            class="w-full <%= button_classes(:primary) %>">
                      <%= t("billing.edit.select_plan") %>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div data-checkout-wizard-target="step2" class="hidden space-y-4">
      <div data-checkout-wizard-target="paidSection" class="hidden">
        <%= render "shared/settings_panel",
                   title: t("billing.checkout.cpf_cnpj_label"),
                   description: t("billing.checkout.cpf_cnpj_description") do %>
          <div class="space-y-2">
            <input type="text" name="cpf_cnpj" id="cpf_cnpj"
                   value="<%= current_user.cpf_cnpj %>"
                   inputmode="numeric"
                   placeholder="000.000.000-00"
                   class="<%= form_input_classes('lg:max-w-xs') %>" />
            <p class="text-xs text-slate-500"><%= t("billing.checkout.cpf_cnpj_hint") %></p>
          </div>
        <% end %>
      </div>

      <div data-checkout-wizard-target="paidSection" class="hidden">
        <%= render "shared/settings_panel",
                   title: t("billing.checkout.payment_method"),
                   description: t("billing.checkout.payment_method_hint") do %>
          <div class="grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
            <% [["pix", t("billing.checkout.pix")], ["credit_card", t("billing.checkout.credit_card")], ["boleto", t("billing.checkout.boleto")]].each_with_index do |(value, label), i| %>
              <label class="settings-choice-card">
                <input type="radio" name="payment_method" value="<%= value %>"
                       <%= i == 0 ? "checked" : "" %>
                       class="h-4 w-4 accent-electric" />
                <span><%= label %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>

      <%= render "shared/settings_action_bar", hint: t("billing.checkout.submit_hint") do %>
        <button type="button"
                data-action="checkout-wizard#back"
                class="<%= "#{button_classes(:secondary)} w-full justify-center lg:w-auto" %>">
          <%= t("billing.checkout.back") %>
        </button>
        <%= f.submit t("billing.checkout.subscribe_button"),
                     class: "#{button_classes(:primary)} w-full justify-center lg:w-auto",
                     data: { turbo_submits_with: t("billing.checkout.submit_loading") } %>
      <% end %>
    </div>
  <% end %>
</div>
