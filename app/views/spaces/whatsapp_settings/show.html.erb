<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("spaces.whatsapp_settings.title") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>
<div class="space-y-6">
  <header>
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
      <%= t("spaces.whatsapp_settings.title") %>
    </h1>
  </header>

  <% if @phone_number&.active? %>
    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-start justify-between">
        <div class="space-y-3">
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("spaces.whatsapp_settings.display_number") %></p>
            <p class="mt-0.5 text-sm font-semibold text-slate-900"><%= @phone_number.display_number %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("spaces.whatsapp_settings.verified_name") %></p>
            <p class="mt-0.5 text-sm text-slate-800"><%= @phone_number.verified_name %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("spaces.whatsapp_settings.status") %></p>
            <span class="mt-0.5 inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
              <%= @phone_number.status.humanize %>
            </span>
          </div>
          <% if @phone_number.quality_rating.present? %>
            <div>
              <p class="text-xs font-medium text-slate-500 uppercase tracking-wide"><%= t("spaces.whatsapp_settings.quality_rating") %></p>
              <p class="mt-0.5 text-sm text-slate-800"><%= @phone_number.quality_rating %></p>
            </div>
          <% end %>
        </div>
      </div>
      <div class="mt-5 border-t border-slate-100 pt-4">
        <%= button_to disconnect_settings_whatsapp_path,
                      method: :delete,
                      class: button_classes(:danger),
                      data: { turbo_confirm: t("spaces.whatsapp_settings.disconnect_confirm") } do %>
          <%= t("spaces.whatsapp_settings.disconnect_button") %>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
      <p class="text-sm text-amber-800"><%= t("spaces.whatsapp_settings.warning") %></p>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm"
         data-controller="whatsapp-signup"
         data-whatsapp-signup-app-id-value="<%= Rails.application.credentials.dig(:whatsapp, :facebook_app_id).to_s %>">
      <p class="text-sm text-slate-600 mb-4"><%= t("spaces.whatsapp_settings.no_number") %></p>

      <%# Hidden form populated and submitted by the Stimulus controller after Meta callback %>
      <%= form_with url: connect_settings_whatsapp_path, method: :post,
                    data: { whatsapp_signup_target: "form" } do |_f| %>
        <input type="hidden" name="whatsapp_phone_number[phone_number_id]"
               data-whatsapp-signup-target="phoneNumberId" value="">
        <input type="hidden" name="whatsapp_phone_number[display_number]"
               data-whatsapp-signup-target="displayNumber" value="">
        <input type="hidden" name="whatsapp_phone_number[waba_id]"
               data-whatsapp-signup-target="wabaId" value="">
        <input type="hidden" name="whatsapp_phone_number[verified_name]"
               data-whatsapp-signup-target="verifiedName" value="">
      <% end %>

      <button type="button"
              class="<%= button_classes(:primary) %>"
              data-action="click->whatsapp-signup#launch">
        <%= t("spaces.whatsapp_settings.connect_button") %>
      </button>
    </div>
  <% end %>
</div>
