<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.settings"), path: edit_settings_space_path },
  { label: t("spaces.whatsapp_settings.title") }
] } %>
<% content_for(:settings_sidebar) do %>
  <%= render "shared/settings_sidebar" %>
<% end %>

<div class="space-y-6">
  <%= render "shared/settings_intro",
             eyebrow: t("settings.sidebar.communication"),
             title: t("spaces.whatsapp_settings.title"),
             subtitle: (@phone_number&.active? ? t("spaces.whatsapp_settings.connected_description") : t("spaces.whatsapp_settings.disconnected_description")),
             statuses: [
               settings_intro_status(t("spaces.whatsapp_settings.status"), (@phone_number&.active? ? t("settings.shared.whatsapp.connected") : t("settings.shared.whatsapp.disconnected")), tone: (@phone_number&.active? ? :success : :warning)),
               (@phone_number&.display_number.present? ? settings_intro_status(t("spaces.whatsapp_settings.display_number"), @phone_number.display_number, tone: :neutral) : nil)
             ] %>

  <% if @phone_number&.active? %>
    <%= render "shared/settings_panel",
               title: t("spaces.whatsapp_settings.connection_title"),
               description: t("spaces.whatsapp_settings.connected_description") do %>
      <div class="grid gap-4 lg:grid-cols-2">
        <div class="settings-info-tile">
          <p class="meta-label"><%= t("spaces.whatsapp_settings.display_number") %></p>
          <p class="mt-1 text-sm font-semibold text-deep"><%= @phone_number.display_number %></p>
        </div>
        <div class="settings-info-tile">
          <p class="meta-label"><%= t("spaces.whatsapp_settings.verified_name") %></p>
          <p class="mt-1 text-sm font-semibold text-deep"><%= @phone_number.verified_name %></p>
        </div>
        <div class="settings-info-tile">
          <p class="meta-label"><%= t("spaces.whatsapp_settings.status") %></p>
          <div class="mt-1">
            <%= render "shared/status_badge",
                       status: @phone_number.status,
                       label: @phone_number.status.humanize %>
          </div>
        </div>
        <% if @phone_number.quality_rating.present? %>
          <div class="settings-info-tile">
            <p class="meta-label"><%= t("spaces.whatsapp_settings.quality_rating") %></p>
            <p class="mt-1 text-sm font-semibold text-deep"><%= @phone_number.quality_rating %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= render "shared/settings_panel",
               title: t("spaces.whatsapp_settings.disconnect_button"),
               description: t("spaces.whatsapp_settings.disconnect_hint") do %>
      <%= button_to disconnect_settings_whatsapp_path,
                    method: :delete,
                    class: "#{button_classes(:danger)} w-full justify-center lg:w-auto",
                    data: { turbo_confirm: t("spaces.whatsapp_settings.disconnect_confirm") } do %>
        <%= t("spaces.whatsapp_settings.disconnect_button") %>
      <% end %>
    <% end %>
  <% else %>
    <%= render "shared/settings_panel",
               title: t("spaces.whatsapp_settings.connection_title"),
               description: t("spaces.whatsapp_settings.disconnected_description") do %>
      <div data-controller="whatsapp-signup"
           data-whatsapp-signup-app-id-value="<%= Rails.application.credentials.dig(:whatsapp, :facebook_app_id).to_s %>"
           class="space-y-4">
        <div class="rounded-card border border-amber-200 bg-amber-50/90 p-4 text-sm leading-6 text-amber-800">
          <%= t("spaces.whatsapp_settings.warning") %>
        </div>

        <%= form_with url: connect_settings_whatsapp_path, method: :post,
                      data: { whatsapp_signup_target: "form" } do |_f| %>
          <input type="hidden" name="whatsapp_phone_number[phone_number_id]"
                 data-whatsapp-signup-target="phoneNumberId" value="">
          <input type="hidden" name="whatsapp_phone_number[display_number]"
                 data-whatsapp-signup-target="displayNumber" value="">
          <input type="hidden" name="whatsapp_phone_number[waba_id]"
                 data-whatsapp-signup-target="wabaId" value="">
          <input type="hidden" name="whatsapp_phone_number[verified_name]"
                 data-whatsapp-signup-target="verifiedName" value="">
        <% end %>

        <%= render "shared/settings_action_bar", hint: t("spaces.whatsapp_settings.connect_hint") do %>
          <button type="button"
                  class="<%= "#{button_classes(:primary)} w-full justify-center lg:w-auto" %>"
                  data-action="click->whatsapp-signup#launch">
            <%= t("spaces.whatsapp_settings.connect_button") %>
          </button>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
