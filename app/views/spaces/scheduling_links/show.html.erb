<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.booking_links"), path: scheduling_links_path },
  { label: @scheduling_link.name.presence || t("space.scheduling_links.show.untitled") }
] } %>
<div class="space-y-4">
  <header class="flex items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold tracking-tight text-slate-900">
        <%= @scheduling_link.name.presence || t("space.scheduling_links.show.untitled") %>
      </h1>
      <p class="mt-1 text-xs text-slate-600">
        <%= @scheduling_link.link_type.humanize %> •
        <% if @scheduling_link.usable? %>
          <span class="text-emerald-600"><%= t("space.scheduling_links.show.active") %></span>
        <% else %>
          <span class="text-slate-500"><%= t("space.scheduling_links.show.inactive") %></span>
        <% end %>
      </p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to t("space.scheduling_links.show.edit"),
                  edit_scheduling_link_path(@scheduling_link),
                  class: button_classes(:primary) %>
    </div>
  </header>

  <div class="panel-card">
    <h2 class="text-sm font-semibold text-slate-800"><%= t("space.scheduling_links.show.booking_url") %></h2>
    <p class="mt-1 text-xs text-slate-600"><%= t("space.scheduling_links.show.copy_hint") %></p>
    <div class="mt-3 flex flex-wrap items-center gap-2">
      <input type="text"
             readonly
             value="<%= book_url(token: @scheduling_link.token) %>"
             class="block flex-1 min-w-0 rounded-md border border-slate-300 bg-slate-50 px-3 py-2 text-sm text-slate-900 font-mono"
             id="booking_url" />
      <button type="button"
              data-controller="clipboard"
              data-clipboard-text-value="<%= book_url(token: @scheduling_link.token) %>"
              data-action="click->clipboard#copy"
              data-copied-text="<%= t("space.scheduling_links.show.copied") %>"
              class="<%= button_classes(:secondary) %>">
        <%= t("space.scheduling_links.show.copy") %>
      </button>
    </div>
  </div>

  <div class="panel-card-compact">
    <dl class="detail-list">
      <div class="detail-list__row">
        <dt class="detail-list__term"><%= t("space.scheduling_links.show.type") %></dt>
        <dd class="detail-list__value"><%= @scheduling_link.link_type.humanize %></dd>
      </div>
      <% if @scheduling_link.single_use? %>
        <div class="detail-list__row">
          <dt class="detail-list__term"><%= t("space.scheduling_links.show.expires_at") %></dt>
          <dd class="detail-list__value"><%= format_datetime_in_zone(@scheduling_link.expires_at, @scheduling_link.space&.timezone) || "—" %></dd>
        </div>
        <div class="detail-list__row">
          <dt class="detail-list__term"><%= t("space.scheduling_links.show.used_at") %></dt>
          <dd class="detail-list__value"><%= format_datetime_in_zone(@scheduling_link.used_at, @scheduling_link.space&.timezone) || t("space.scheduling_links.show.not_used") %></dd>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="flex flex-wrap gap-3">
    <%= link_to t("space.scheduling_links.show.open_link"),
                book_path(token: @scheduling_link.token),
                target: "_blank",
                rel: "noopener",
                class: button_classes(:table_link) %>
  </div>
</div>
