<% content_for(:breadcrumbs) { render "shared/breadcrumbs", crumbs: [
  { label: t("breadcrumbs.dashboard"), path: root_path },
  { label: t("breadcrumbs.booking_links") }
] } %>

<div class="space-y-6">
  <%= render "spaces/scheduling_links/links_overview",
             space: current_tenant,
             personalized_link: @personalized_link %>

  <% if current_user.can?(:manage_personalized_links) %>
    <%= render "spaces/scheduling_links/personalized_link_card",
               space: current_tenant,
               personalized_link: @personalized_link %>
  <% end %>

  <%= render "shared/settings_panel",
             title: t("space.scheduling_links.index.library.title"),
             description: t("space.scheduling_links.index.library.description") do %>
    <div data-role="link-library-panel" class="space-y-5">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="space-y-1">
          <p class="text-sm font-medium text-slate-700"><%= t("space.scheduling_links.index.library.action_hint") %></p>
          <% unless Billing::PlanEnforcer.can?(current_tenant, :create_scheduling_link) %>
            <p class="text-sm leading-6 text-slate-500"><%= t("billing.limits.scheduling_links_exceeded") %></p>
          <% end %>
        </div>

        <% if Billing::PlanEnforcer.can?(current_tenant, :create_scheduling_link) %>
          <%= link_to t("space.scheduling_links.index.new_button"),
                      new_scheduling_link_path,
                      class: button_classes(:primary) %>
        <% end %>
      </div>

      <% if @scheduling_links.any? %>
        <div class="space-y-3">
          <%= render partial: "spaces/scheduling_links/scheduling_link_row",
                     collection: @scheduling_links,
                     as: :scheduling_link %>
        </div>
      <% else %>
        <div data-role="scheduling-links-empty-state" class="rounded-[1.4rem] border border-dashed border-slate-200 bg-slate-50/80 p-6 text-center">
          <h3 class="text-base font-semibold text-deep"><%= t("space.scheduling_links.index.library.empty_title") %></h3>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= t("space.scheduling_links.index.library.empty_body") %></p>

          <% if Billing::PlanEnforcer.can?(current_tenant, :create_scheduling_link) %>
            <div class="mt-4">
              <%= link_to t("space.scheduling_links.index.create_cta"),
                          new_scheduling_link_path,
                          class: button_classes(:primary) %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
