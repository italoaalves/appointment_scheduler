<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= t("errors.internal_server_error.title") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="robots" content="noindex,nofollow">
    <%= csrf_meta_tags %>
    <style>
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: #f8fafc;
        color: #0f172a;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      main {
        width: min(100%, 32rem);
        padding: 32px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        background: #ffffff;
      }
      h1 {
        margin: 0 0 12px;
        font-size: 1.75rem;
        line-height: 1.2;
      }
      p {
        margin: 0 0 12px;
        line-height: 1.6;
      }
      code {
        display: inline-block;
        padding: 2px 6px;
        border-radius: 6px;
        background: #e2e8f0;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.95rem;
      }
    </style>
  </head>
  <body>
    <main>
      <h1><%= t("errors.internal_server_error.heading") %></h1>
      <p><%= t("errors.internal_server_error.message") %></p>
      <p><%= t("errors.internal_server_error.reference", request_id: request_id) %></p>
    </main>
  </body>
</html>
