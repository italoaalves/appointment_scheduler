<% amount = number_to_currency(@payment.amount_cents / 100.0, unit: "R$", separator: ",", delimiter: ".") %>
<% content_for :email_preheader, "A chargeback event was received for #{@space.name}." %>
<% content_for :email_eyebrow, "Billing" %>
<% content_for :email_title, "Chargeback alert" %>
<% content_for :email_intro, "An operational review is needed for this payment event." %>

<%= render "shared/mailer/callout",
           title: "Action required",
           tone: "danger",
           content: "A chargeback event was received for #{@space.name}." %>

<%= render "shared/mailer/metadata", rows: [
  { label: "Event", value: @event_name },
  { label: "Reason", value: @reason.presence || "Not provided" },
  { label: "Payment ID", value: @payment.asaas_payment_id },
  { label: "Amount", value: amount },
  { label: "Space", value: "#{@space.name} (ID: #{@space.id})" }
] %>

<p style="margin: 20px 0 0;">Review in the platform admin dashboard and take the next billing action there.</p>
