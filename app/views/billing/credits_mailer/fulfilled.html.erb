<% content_for :email_preheader, t("billing.credits_mailer.fulfilled.body", amount: @amount) %>
<% content_for :email_eyebrow, t("mailers.shared.eyebrows.billing") %>
<% content_for :email_title, message.subject %>
<% content_for :email_intro, t("billing.credits_mailer.fulfilled.intro") %>
<% content_for :email_cta_label, t("billing.credits_mailer.fulfilled.cta") %>
<% content_for :email_cta_url, settings_credits_url %>

<%= render "shared/mailer/callout",
           title: t("billing.credits_mailer.fulfilled.callout_title"),
           tone: "success",
           content: t("billing.credits_mailer.fulfilled.body", amount: @amount) %>

<%= render "shared/mailer/metadata", rows: [
  { label: t("billing.credits_mailer.shared.metadata.amount"), value: @amount.to_s },
  { label: t("billing.credits_mailer.shared.metadata.space"), value: @space.name }
] %>
