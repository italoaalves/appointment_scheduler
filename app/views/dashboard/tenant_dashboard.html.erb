<%# Mission Control Dashboard — hero · utility row · attention + calendar hub %>
<% today_summary     = @overview[:today_summary] %>
<% attention         = @overview[:attention] %>

<%= turbo_stream_from [current_tenant, :dashboard_calendar] %>

<div class="space-y-6 md:space-y-8">
  <%# Onboarding / welcome states %>
  <% if current_tenant.onboarding_complete? && current_tenant.personalized_scheduling_link.present? %>
    <% unless current_user.user_preference&.dismissed_welcome_card %>
      <%= render "dashboard/welcome_card" %>
    <% end %>
  <% else %>
    <%= render "dashboard/setup_checklist", space: current_tenant %>
  <% end %>

  <%# Hero — full width %>
  <div class="dashboard-region dashboard-region--0">
    <%= render "dashboard/today_hero",
               today_summary: today_summary,
               space: current_tenant,
               current_user: current_user %>
  </div>

  <%# Two-column bento: left sidebar + calendar %>
  <div class="grid min-w-0 gap-6 md:max-h-[65vh] md:grid-cols-[minmax(0,1fr)_minmax(0,3fr)] md:gap-8">
    <%# Left column — Quick Actions + Attention stacked %>
    <div class="flex min-w-0 flex-col gap-6 md:gap-8">
      <div class="dashboard-region dashboard-region--50 flex flex-col">
        <%= render "dashboard/quick_actions", space: current_tenant %>
      </div>

      <div class="dashboard-region dashboard-region--150 flex flex-col">
        <%= render "dashboard/attention_queue", attention: attention %>
      </div>
    </div>

    <%# Right column — Calendar %>
    <%= render "dashboard/calendar_sync", space: current_tenant %>
  </div>
</div>
