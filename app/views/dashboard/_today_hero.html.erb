<%# Locals: today_summary, space, current_user %>
<% tz        = TimezoneResolver.zone(space) %>
<% now_local = Time.current.in_time_zone(tz) %>
<% hour      = now_local.hour %>
<% time_of_day = case hour
                 when 5..11  then :morning
                 when 12..17 then :afternoon
                 when 18..20 then :evening
                 else             :night
                 end %>

<div class="card-glass glass-liquid card-spacious">
  <p class="text-xs font-semibold uppercase tracking-widest text-slate-500/70">
    <%= l(now_local.to_date, format: :long) %>
  </p>

  <h1 class="mt-2 font-display text-2xl font-semibold leading-tight text-deep md:text-3xl">
    <%= greeting_for(time_of_day, current_user) %>
  </h1>

  <div class="mt-3">
    <% if today_summary[:total] > 0 %>
      <p class="font-body text-base text-slate-600">
        <%= t("dashboard.hero.summary_html",
              total:     tag.span(today_summary[:total],     class: "font-mono tabular-nums text-deep"),
              confirmed: tag.span(today_summary[:confirmed], class: "font-mono tabular-nums text-emerald-700"),
              pending:   tag.span(today_summary[:pending],   class: "font-mono tabular-nums text-amber-700")) %>
      </p>
      <%= render "dashboard/day_shape", blocks: today_summary[:blocks], space: space %>
    <% else %>
      <p class="font-body text-base text-slate-500"><%= t("dashboard.hero.empty") %></p>
    <% end %>
  </div>
</div>
