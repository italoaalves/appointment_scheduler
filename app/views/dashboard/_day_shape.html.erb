<%# Locals: blocks (array of {from:, to:, state:}), space %>
<%# Horizontal bar of thin segments proportional to time blocks in the space's timezone. %>
<% tz = TimezoneResolver.zone(space) %>

<div class="relative mt-5 h-2 w-full overflow-hidden rounded-full bg-slate-100/80">
  <svg class="h-full w-full" viewBox="0 0 100 8" preserveAspectRatio="none" aria-hidden="true">
    <% blocks.each do |block| %>
      <%
        from_local = block[:from].in_time_zone(tz)
        to_local = block[:to].in_time_zone(tz)
        start_pct = (from_local.seconds_since_midnight / 86400.0 * 100).clamp(0, 100)
        end_pct = (to_local.seconds_since_midnight / 86400.0 * 100).clamp(0, 100)
        width_pct = [end_pct - start_pct, 0.5].max
        fill_color = block[:state].to_s == "confirmed" ? "rgb(16 185 129 / 0.6)" : "rgb(251 191 36 / 0.6)"
      %>
      <rect x="<%= start_pct.round(2) %>" y="0" width="<%= width_pct.round(2) %>" height="8" rx="1.5" fill="<%= fill_color %>"></rect>
    <% end %>
  </svg>
</div>
