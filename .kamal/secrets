# Decrypt staging credentials without booting Rails (fast, no DB dependency).
read_credential() {
  ruby -r yaml -r active_support/encrypted_configuration -e "
    creds = ActiveSupport::EncryptedConfiguration.new(
      config_path: 'config/credentials/staging.yml.enc',
      key_path: 'config/credentials/staging.key',
      env_key: 'RAILS_MASTER_KEY',
      raise_if_missing_key: true
    )
    value = creds.dig(*ARGV.map(&:to_sym))
    abort \"ERROR: credential #{ARGV.join('.')} is missing\" if value.nil? || value.empty?
    print value
  " "$@"
}

# Registry password (ghcr.io)
KAMAL_REGISTRY_PASSWORD=$(read_credential kamal deploy token)

# Staging credentials key — used as RAILS_MASTER_KEY since RAILS_ENV=staging
RAILS_MASTER_KEY=$(cat config/credentials/staging.key)

# PostgreSQL password for the DB accessory
POSTGRES_PASSWORD=$(read_credential postgres password)

# Fail fast if any secret is empty
for var in KAMAL_REGISTRY_PASSWORD RAILS_MASTER_KEY POSTGRES_PASSWORD; do
  if [ -z "$(eval echo \$$var)" ]; then
    echo "FATAL: $var is empty — aborting deploy" >&2
    exit 1
  fi
done
