# Registry password (ghcr.io)
KAMAL_REGISTRY_PASSWORD=$(RAILS_LOG_TO_STDOUT=false bin/rails runner -e staging "puts Rails.application.credentials.dig(:kamal, :deploy, :token)" 2>/dev/null | tail -1)

# Rails master key (default credentials)
RAILS_MASTER_KEY=$(cat config/master.key)

# Staging-specific credentials key
RAILS_STAGING_MASTER_KEY=$(cat config/credentials/staging.key)

# PostgreSQL password for the DB accessory
POSTGRES_PASSWORD=$(RAILS_LOG_TO_STDOUT=false bin/rails runner -e staging "puts Rails.application.credentials.dig(:postgres, :password)" 2>/dev/null | tail -1)
